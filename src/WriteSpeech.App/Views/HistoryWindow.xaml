<Window x:Class="WriteSpeech.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WriteSpeech.App.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Icon="/Resources/Icons/app.ico"
        Width="420" Height="520"
        Title="Transcription History"
        AutomationProperties.Name="Transcription History">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/SettingsDarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/SettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibility"/>
            <converters:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibility"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        <Border x:Name="ClipBorder" CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Accent stripe -->
                <Border Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#9B7DFF" Offset="0"/>
                            <GradientStop Color="#7C5CFC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Title bar -->
                <Grid Grid.Row="1" Height="40" Background="{DynamicResource SidebarBgBrush}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource SelectedBorderBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Transcription History" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                            AutomationProperties.Name="Close"
                            Cursor="Hand" Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Search box -->
                <Grid Grid.Row="2" Margin="12,8,12,0">
                    <Border x:Name="SearchBorder" Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                            BorderThickness="1" BorderBrush="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1"
                                     AutomationProperties.Name="Search history"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" FontFamily="Segoe UI"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     VerticalAlignment="Center" Margin="6,0,0,0"
                                     BorderThickness="0" Background="Transparent" Padding="0,6"
                                     GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                            <TextBlock Grid.Column="1" Text="Search transcriptions..."
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="6,0,0,0" Padding="0,6"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SearchQuery, Converter={StaticResource EmptyStringToVisibility}}"/>
                            <Button Grid.Column="2" Cursor="Hand"
                                    Command="{Binding ClearSearchCommand}"
                                    Visibility="{Binding SearchQuery, Converter={StaticResource NonEmptyStringToVisibility}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                                Width="26" Height="26" Margin="0,0,4,0">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Entry list -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="12,8,12,0">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                        Margin="0,0,0,6" ClipToBounds="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left accent stripe -->
                                        <Border Grid.Column="0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#9B7DFF" Offset="0"/>
                                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- Entry content -->
                                        <Grid Grid.Column="1" Margin="12,10,14,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Text preview + provider badge + time -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Preview}" FontSize="12" FontFamily="Segoe UI"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                           MaxHeight="38"/>
                                                <Border Grid.Column="1" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="4" Padding="5,1" VerticalAlignment="Top"
                                                        Margin="6,0,0,0"
                                                        BorderBrush="{DynamicResource SelectedBorderBrush}"
                                                        BorderThickness="1" Opacity="0.9">
                                                    <TextBlock Text="{Binding Provider}" FontSize="9"
                                                               FontFamily="Segoe UI"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" FontSize="10"
                                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Top" Margin="6,0,0,0"/>
                                            </Grid>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                                                <!-- Copy button (accent pill) -->
                                                <Button Cursor="Hand"
                                                        AutomationProperties.Name="Copy"
                                                        Command="{Binding DataContext.CopyEntryCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" CornerRadius="12" Padding="10,4">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#9B7DFF" Offset="0"/>
                                                                        <GradientStop Color="#7C5CFC" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                                    <TextBlock Text="Copy" Foreground="White" VerticalAlignment="Center"
                                                                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <!-- Remove button (icon) -->
                                                <Button Cursor="Hand" Margin="6,0,0,0"
                                                        AutomationProperties.Name="Remove"
                                                        Command="{Binding DataContext.RemoveEntryCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="Transparent"
                                                                    CornerRadius="6" Width="26" Height="26">
                                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- No results message -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding ShowNoResults, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="No matching transcriptions found."
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Bottom bar -->
                <Border Grid.Row="4" Background="{DynamicResource SidebarBgBrush}" Padding="12,8"
                        CornerRadius="0,0,12,12">
                    <Grid>
                        <TextBlock Text="{Binding EntryCountDisplay}"
                                   FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Cursor="Hand"
                                AutomationProperties.Name="Clear all"
                                Command="{Binding ClearAllCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                            CornerRadius="14" Padding="12,5"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Clear all" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
