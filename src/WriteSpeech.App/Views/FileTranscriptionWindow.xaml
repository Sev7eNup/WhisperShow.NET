<Window x:Class="WriteSpeech.App.Views.FileTranscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WriteSpeech.App.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Icon="/Resources/Icons/app.ico"
        Width="480" Height="540"
        Title="Transcribe File"
        AutomationProperties.Name="Transcribe File">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/SettingsDarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/SettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        <Border x:Name="ClipBorder" CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Accent stripe -->
                <Border Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#9B7DFF" Offset="0"/>
                            <GradientStop Color="#7C5CFC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Title bar -->
                <Grid Grid.Row="1" Height="40" Background="{DynamicResource SidebarBgBrush}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="&#xEC4F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource SelectedBorderBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Transcribe File" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                            AutomationProperties.Name="Close"
                            Cursor="Hand" Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ============ FILE SELECTION PANEL ============ -->
                <Grid Grid.Row="2"
                      Visibility="{Binding IsSelectingFile, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Drop zone -->
                    <Border x:Name="DropZoneBorder" Grid.Row="0" Margin="16,12,16,0" CornerRadius="12" Padding="24,20"
                            AllowDrop="True"
                            DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave"
                            DragOver="DropZone_DragOver" Drop="DropZone_Drop"
                            BorderThickness="1.5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#9B7DFF"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#1A9B7DFF"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Audio icon -->
                            <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="24"
                                    Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SelectedBorderBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Drop hint text -->
                            <TextBlock Text="Drop audio file here" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="or" FontSize="12"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- Browse button -->
                            <Button Cursor="Hand" HorizontalAlignment="Center"
                                    AutomationProperties.Name="Select audio file"
                                    Click="BrowseButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="16" Padding="20,7">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#9B7DFF" Offset="0"/>
                                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Browse files" Foreground="White" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Supported formats -->
                            <TextBlock Text="MP3, WAV, M4A, FLAC, OGG, MP4" FontSize="11"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" Opacity="0.7"/>
                        </StackPanel>
                    </Border>

                    <!-- Error message (selection phase) -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="18,6,16,0"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVis}}">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="#FFE53935" VerticalAlignment="Top" Margin="0,1,6,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#FFE53935" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Recent files section -->
                    <StackPanel Grid.Row="2" Margin="16,8,16,16">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentFiles.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Recent files" FontSize="12" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="2,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding RecentFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Cursor="Hand" Margin="0,0,0,2"
                                            Click="RecentFile_Click" Tag="{Binding FilePath}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="8,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                   Foreground="{DynamicResource SelectedBorderBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FileName}" FontSize="12"
                                                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding FileInfo}" FontSize="10"
                                                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" FontSize="10"
                                                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- ============ TRANSCRIPTION PANEL ============ -->
                <Grid Grid.Row="2"
                      Visibility="{Binding IsSelectingFile, Converter={StaticResource InverseBoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- File info card -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                            Margin="12,10,12,0" ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Left accent stripe -->
                            <Border Grid.Column="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#9B7DFF" Offset="0"/>
                                        <GradientStop Color="#7C5CFC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- File info content -->
                            <Grid Grid.Column="1" Margin="12,10,14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="8"
                                        Width="36" Height="36" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{DynamicResource SelectedBorderBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding FileInfo}" FontSize="11"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Progress / Status -->
                    <StackPanel Grid.Row="1" Margin="12,10,12,0">
                        <Border CornerRadius="2" ClipToBounds="True"
                                Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}">
                            <ProgressBar IsIndeterminate="{Binding IsTranscribing}" Height="4"
                                         Background="{DynamicResource CardBgBrush}" BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#9B7DFF" Offset="0"/>
                                        <GradientStop Color="#7C5CFC" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </Border>
                        <TextBlock Text="{Binding StatusText}" FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Result text -->
                    <Border Grid.Row="2" CornerRadius="10" Margin="12,8,12,0"
                            Background="{DynamicResource CardBgBrush}" ClipToBounds="True">
                        <TextBox Text="{Binding ResultText, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13" FontFamily="Segoe UI"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 Background="Transparent"
                                 BorderThickness="0" Padding="14,10"/>
                    </Border>

                    <!-- Error message -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="14,6,12,0"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVis}}">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="#FFE53935" VerticalAlignment="Top" Margin="0,1,6,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#FFE53935" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Bottom bar -->
                    <Border Grid.Row="4" Background="{DynamicResource SidebarBgBrush}" Padding="12,8"
                            CornerRadius="0,0,12,12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <!-- Accent Copy button -->
                                <Button Cursor="Hand" FontSize="11" FontFamily="Segoe UI"
                                        AutomationProperties.Name="Copy result"
                                        Command="{Binding CopyResultCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="14" Padding="14,6">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#9B7DFF" Offset="0"/>
                                                        <GradientStop Color="#7C5CFC" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Copy" Foreground="White" VerticalAlignment="Center"
                                                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Copied feedback -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                                            Visibility="{Binding IsCopied, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="#FF66BB6A" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Copied!" FontSize="11" FontFamily="Segoe UI"
                                               Foreground="#FF66BB6A" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- New File button -->
                                <Button Cursor="Hand" FontSize="11" FontFamily="Segoe UI"
                                        AutomationProperties.Name="New transcription"
                                        Click="NewFileButton_Click"
                                        Visibility="{Binding IsTranscribing, Converter={StaticResource InverseBoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                    CornerRadius="14" Padding="14,6"
                                                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="New File" Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Cancel button -->
                                <Button Cursor="Hand" FontSize="11" FontFamily="Segoe UI" Margin="6,0,0,0"
                                        AutomationProperties.Name="Cancel"
                                        Command="{Binding CancelCommand}"
                                        Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                    CornerRadius="14" Padding="14,6"
                                                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Cancel" Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
