<Window x:Class="WriteSpeech.App.Views.FileTranscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Icon="/Resources/Icons/app.ico"
        Width="480" Height="420"
        Title="Transcribe File">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/SettingsDarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/SettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        <Border x:Name="ClipBorder" CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Accent stripe -->
                <Border Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#9B7DFF" Offset="0"/>
                            <GradientStop Color="#7C5CFC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Title bar -->
                <Grid Grid.Row="1" Height="40" Background="{DynamicResource SidebarBgBrush}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="&#xEC4F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource SelectedBorderBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Transcribe File" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                            Cursor="Hand" Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="28" Height="28">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- File info card -->
                <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                        Margin="12,10,12,0" ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Left accent stripe -->
                        <Border Grid.Column="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#9B7DFF" Offset="0"/>
                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- File info content -->
                        <Grid Grid.Column="1" Margin="12,10,14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="8"
                                    Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource SelectedBorderBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding FileInfo}" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Progress / Status -->
                <StackPanel Grid.Row="3" Margin="12,10,12,0">
                    <Border CornerRadius="2" ClipToBounds="True"
                            Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar IsIndeterminate="{Binding IsTranscribing}" Height="4"
                                     Background="{DynamicResource CardBgBrush}" BorderThickness="0">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#9B7DFF" Offset="0"/>
                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </Border>
                    <TextBlock Text="{Binding StatusText}" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Result text -->
                <Border Grid.Row="4" CornerRadius="10" Margin="12,8,12,0"
                        Background="{DynamicResource CardBgBrush}" ClipToBounds="True">
                    <TextBox Text="{Binding ResultText, Mode=OneWay}"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="13" FontFamily="Segoe UI"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             Background="Transparent"
                             BorderThickness="0" Padding="14,10"/>
                </Border>

                <!-- Error message -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="14,6,12,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="#FFE53935" VerticalAlignment="Top" Margin="0,1,6,0"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12" FontFamily="Segoe UI"
                               Foreground="#FFE53935" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Bottom bar -->
                <Border Grid.Row="6" Background="{DynamicResource SidebarBgBrush}" Padding="12,8"
                        CornerRadius="0,0,12,12">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <!-- Accent Copy button -->
                            <Button Cursor="Hand" FontSize="11" FontFamily="Segoe UI"
                                    Command="{Binding CopyResultCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="14" Padding="14,6">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#9B7DFF" Offset="0"/>
                                                    <GradientStop Color="#7C5CFC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Copy" Foreground="White" VerticalAlignment="Center"
                                                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Copied feedback -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                                        Visibility="{Binding IsCopied, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#FF66BB6A" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Copied!" FontSize="11" FontFamily="Segoe UI"
                                           Foreground="#FF66BB6A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Cancel button -->
                        <Button HorizontalAlignment="Right" Cursor="Hand"
                                FontSize="11" FontFamily="Segoe UI"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                            CornerRadius="14" Padding="14,6"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Cancel" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
