<UserControl x:Class="WriteSpeech.App.Views.Settings.ModelsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WriteSpeech.App.Converters"
             xmlns:local="clr-namespace:WriteSpeech.App.ViewModels.Settings">
    <StackPanel DataContext="{Binding Transcription}">
        <TextBlock Text="Models" Style="{StaticResource PageTitleStyle}"/>
        <TextBlock Text="Choose your transcription provider and configure model settings."
                   FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <!-- Provider picker cards -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Cloud card -->
            <Border Grid.Column="0" Tag="OpenAI" MouseLeftButtonDown="ProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="OpenAI">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Cloud" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="OpenAI Whisper API" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12.5"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}"/>
                </Grid>
            </Border>

            <!-- Local card (selected for both Local and Parakeet providers) -->
            <Border Grid.Column="2" Tag="Local" MouseLeftButtonDown="ProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="Local">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Provider}" Value="Parakeet">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Local" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Whisper.net &amp; Parakeet" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12.5"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=Local|Parakeet}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Cloud settings (visible when Provider=OpenAI) ===== -->
        <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}">
            <TextBlock Text="Cloud settings" Style="{StaticResource GroupHeaderStyle}"/>

            <!-- Pill navigation: OpenAI | Groq | Custom -->
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="20" Padding="4" Margin="0,0,0,12"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <!-- OpenAI tab -->
                    <Border Tag="OpenAI" MouseLeftButtonDown="CloudSubProviderTab_Click" Cursor="Hand"
                            CornerRadius="16" Padding="16,6" Margin="0,0,2,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="OpenAI">
                                        <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="OpenAI" FontSize="11.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="OpenAI">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <!-- Groq tab -->
                    <Border Tag="Groq" MouseLeftButtonDown="CloudSubProviderTab_Click" Cursor="Hand"
                            CornerRadius="16" Padding="16,6" Margin="0,0,2,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="Groq">
                                        <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Groq" FontSize="11.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="Groq">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <!-- Custom tab -->
                    <Border Tag="Custom" MouseLeftButtonDown="CloudSubProviderTab_Click" Cursor="Hand"
                            CornerRadius="16" Padding="16,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="Custom">
                                        <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="Custom" FontSize="11.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="Custom">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== OpenAI sub-provider ===== -->
            <StackPanel Visibility="{Binding CloudTranscriptionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=OpenAI}">
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- API Key -->
                        <Grid Margin="20,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingApiKey, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="API Key" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding OpenAiApiKeyDisplay}" FontSize="11.5"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingApiKey, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding OpenAiApiKey}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="ApiKeyTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding StartEditingApiKeyCommand}" VerticalAlignment="Center"
                                    Visibility="{Binding IsEditingApiKey, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Model picker -->
                        <StackPanel Margin="20,10,20,10">
                            <TextBlock Text="Model" FontSize="12.5" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{x:Static local:TranscriptionSettingsViewModel.CloudTranscriptionModels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" Padding="12,8" Cursor="Hand"
                                                Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                                BorderThickness="2"
                                                MouseLeftButtonDown="CloudModelCard_Click" Tag="{Binding Id}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                    <Binding Path="Id"/>
                                                                    <Binding Path="DataContext.TranscriptionModel"
                                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11.5" FontWeight="SemiBold"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10.5"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ===== Groq sub-provider ===== -->
            <StackPanel Visibility="{Binding CloudTranscriptionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Groq}">
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- API Key -->
                        <Grid Margin="20,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingGroqTranscriptionApiKey, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="API Key" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding GroqTranscriptionApiKeyDisplay}" FontSize="11.5"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingGroqTranscriptionApiKey, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding GroqTranscriptionApiKey}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="GroqTranscriptionApiKeyTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Cursor="Hand" VerticalAlignment="Center" Click="StartEditGroqTranscriptionApiKey_Click"
                                    Visibility="{Binding IsEditingGroqTranscriptionApiKey, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Model picker -->
                        <StackPanel Margin="20,10,20,10">
                            <TextBlock Text="Model" FontSize="12.5" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{x:Static local:TranscriptionSettingsViewModel.GroqTranscriptionModels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" Padding="12,8" Cursor="Hand"
                                                Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                                BorderThickness="2"
                                                MouseLeftButtonDown="GroqTranscriptionModelCard_Click" Tag="{Binding Id}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                    <Binding Path="Id"/>
                                                                    <Binding Path="DataContext.GroqTranscriptionModel"
                                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11.5" FontWeight="SemiBold"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10.5"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ===== Custom sub-provider ===== -->
            <StackPanel Visibility="{Binding CloudTranscriptionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Custom}">
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- API Endpoint -->
                        <Grid Margin="20,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingCustomTranscriptionEndpoint, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="API Endpoint" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding CustomTranscriptionEndpoint}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CustomTranscriptionEndpoint}" Value="">
                                                    <Setter Property="Text" Value="Not configured"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingCustomTranscriptionEndpoint, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding CustomTranscriptionEndpoint}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="CustomTranscriptionEndpointTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Cursor="Hand" VerticalAlignment="Center" Click="StartEditCustomTranscriptionEndpoint_Click"
                                    Visibility="{Binding IsEditingCustomTranscriptionEndpoint, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- API Key -->
                        <Grid Margin="20,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingCustomTranscriptionApiKey, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="API Key" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CustomTranscriptionApiKeyDisplay}" FontSize="11.5"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingCustomTranscriptionApiKey, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding CustomTranscriptionApiKey}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="CustomTranscriptionApiKeyTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Cursor="Hand" VerticalAlignment="Center" Click="StartEditCustomTranscriptionApiKey_Click"
                                    Visibility="{Binding IsEditingCustomTranscriptionApiKey, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Model name -->
                        <Grid Margin="20,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingCustomTranscriptionModel, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="Model" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding CustomTranscriptionModel}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CustomTranscriptionModel}" Value="">
                                                    <Setter Property="Text" Value="Not configured"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingCustomTranscriptionModel, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding CustomTranscriptionModel}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="CustomTranscriptionModelTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Cursor="Hand" VerticalAlignment="Center" Click="StartEditCustomTranscriptionModel_Click"
                                    Visibility="{Binding IsEditingCustomTranscriptionModel, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ===== Local settings (visible when Provider=Local or Parakeet) ===== -->
        <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=Local|Parakeet}">
            <TextBlock Text="Local settings" Style="{StaticResource GroupHeaderStyle}"/>
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                <StackPanel>
                    <!-- GPU acceleration (shared for Whisper + Parakeet) -->
                    <Grid Margin="20,10,20,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GPU acceleration" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding GpuAcceleration}"
                                      Command="{Binding ToggleGpuAccelerationCommand}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Whisper models -->
            <TextBlock Text="Whisper models" Style="{StaticResource GroupHeaderStyle}"/>
            <ItemsControl ItemsSource="{Binding Models.ModelItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12"
                                Padding="20,10" Margin="0,0,0,8" BorderThickness="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="11.5"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding StatusText}" FontSize="10.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   Margin="0,3,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SelectedBorderBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Download button (!IsDownloaded && !IsDownloading) -->
                                    <Button Grid.Column="1" Content="Download" Cursor="Hand"
                                            FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Models.DownloadModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelActionVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="10" Padding="14,6"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Use button (IsDownloaded && !IsActive && !IsDownloading) -->
                                    <Button Grid.Column="1" Content="Use" Cursor="Hand"
                                            FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Models.ActivateModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelUseVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                                <Binding Path="IsActive"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#7C5CFC"
                                                        CornerRadius="10" Padding="14,6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </Button.Foreground>
                                    </Button>

                                    <!-- Delete button (IsDownloaded && !IsActive && !IsDownloading) -->
                                    <Button Grid.Column="2" Content="Delete" Cursor="Hand"
                                            FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            VerticalAlignment="Center" Margin="6,0,0,0"
                                            Command="{Binding DataContext.Models.DeleteModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelDeleteVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                                <Binding Path="IsActive"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="10" Padding="14,6"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Progress bar -->
                                <ProgressBar Grid.Row="1" Minimum="0" Maximum="1"
                                             Value="{Binding DownloadProgress}"
                                             Height="4" Margin="0,8,0,0"
                                             Foreground="#7C5CFC"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Parakeet models (English only) -->
            <TextBlock Text="Parakeet models (English only)" Style="{StaticResource GroupHeaderStyle}"/>
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,0,0,8" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#x2139;" FontSize="12.5" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Top" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="10.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="NVIDIA Parakeet supports English only. For other languages, use a Whisper model."/>
                </Grid>
            </Border>
            <ItemsControl ItemsSource="{Binding Models.ParakeetModelItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12"
                                Padding="20,10" Margin="0,0,0,8" BorderThickness="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="11.5"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding StatusText}" FontSize="10.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   Margin="0,3,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SelectedBorderBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Download button -->
                                    <Button Grid.Column="1" Content="Download" Cursor="Hand"
                                            FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Models.DownloadParakeetModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelActionVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="10" Padding="14,6"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Use button -->
                                    <Button Grid.Column="1" Content="Use" Cursor="Hand"
                                            FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Models.ActivateParakeetModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelUseVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                                <Binding Path="IsActive"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#7C5CFC"
                                                        CornerRadius="10" Padding="14,6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </Button.Foreground>
                                    </Button>

                                    <!-- Delete button -->
                                    <Button Grid.Column="2" Content="Delete" Cursor="Hand"
                                            FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            VerticalAlignment="Center" Margin="6,0,0,0"
                                            Command="{Binding DataContext.Models.DeleteParakeetModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelDeleteVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                                <Binding Path="IsActive"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="10" Padding="14,6"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Progress bar -->
                                <ProgressBar Grid.Row="1" Minimum="0" Maximum="1"
                                             Value="{Binding DownloadProgress}"
                                             Height="4" Margin="0,8,0,0"
                                             Foreground="#7C5CFC"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- ===== Combined Audio Model section (only for Cloud provider + OpenAI sub-provider) ===== -->
        <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}">
        <StackPanel Visibility="{Binding CloudTranscriptionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=OpenAI}">
        <TextBlock Text="Combined Audio Model" Style="{StaticResource GroupHeaderStyle}" Margin="0,20,0,8"/>
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
            <StackPanel>
                <Grid Margin="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#x2139;" FontSize="12.5" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Top" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="10.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Sends audio directly to OpenAI for transcription + correction in a single API call. Requires an API key."/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                <Grid Margin="20,10,20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Combined audio model" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CombinedAudioModel}" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"
                                   Visibility="{Binding UseCombinedAudioModel, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Change" Style="{StaticResource PillButtonStyle}"
                                Command="{Binding StartEditingCombinedAudioModelCommand}"
                                VerticalAlignment="Center" Margin="0,0,10,0"
                                Visibility="{Binding UseCombinedAudioModel, Converter={StaticResource BoolToVisibility}}"/>
                        <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding UseCombinedAudioModel}"
                                      Command="{Binding ToggleCombinedAudioModelCommand}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="20,0,20,14"
                      Visibility="{Binding IsEditingCombinedAudioModel, Converter={StaticResource BoolToVisibility}}">
                    <TextBox Text="{Binding CombinedAudioModel}" Style="{StaticResource SettingsTextBoxStyle}"
                             KeyDown="CombinedAudioModelTextBox_KeyDown"/>
                </Grid>
            </StackPanel>
        </Border>
        </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
