<UserControl x:Class="WriteSpeech.App.Views.Settings.StatisticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel DataContext="{Binding Statistics}">
        <TextBlock Text="Statistics" Style="{StaticResource PageTitleStyle}"/>
        <TextBlock Text="Usage statistics for your transcription sessions."
                   FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <!-- Stats cards -->
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
            <StackPanel>
                <!-- Total transcriptions -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Total transcriptions" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TotalTranscriptions}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Total recording time -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Total recording time" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding TotalRecordingTimeDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Average duration -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Average duration" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding AverageDurationDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Words transcribed -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Words transcribed" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding WordsTranscribedDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Estimated time saved -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Estimated time saved" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Based on 40 WPM average typing speed" FontSize="10.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding TimeSavedDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Success rate -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Success rate" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SuccessRateDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Longest recording -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Longest recording" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding LongestRecordingDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Shortest recording -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Shortest recording" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ShortestRecordingDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Estimated API cost -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Estimated API cost" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Based on $0.006/min (Whisper API)" FontSize="10.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding EstimatedCostDisplay}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Errors -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Errors" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ErrorCount}" FontSize="18"
                               FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Provider breakdown -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="By provider" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProviderBreakdownDisplay}" FontSize="12.5"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Correction provider breakdown -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="By correction provider" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding CorrectionBreakdownDisplay}" FontSize="12.5"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Refresh" Style="{StaticResource PillButtonStyle}"
                    Command="{Binding RefreshCommand}" Margin="0,0,10,0"/>
            <Button Content="Reset all" Style="{StaticResource PillButtonStyle}"
                    Command="{Binding ResetCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
