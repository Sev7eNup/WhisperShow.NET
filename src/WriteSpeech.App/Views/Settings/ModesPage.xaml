<UserControl x:Class="WriteSpeech.App.Views.Settings.ModesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel DataContext="{Binding Modes}">
        <TextBlock Text="Modes" Style="{StaticResource PageTitleStyle}"/>
        <TextBlock Text="Context-aware correction modes. Each mode has its own system prompt for different use cases."
                   FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="4,-4,0,16"/>

        <!-- Auto-Switch Toggle -->
        <TextBlock Text="Auto-switch" Style="{StaticResource GroupHeaderStyle}" Margin="4,0,0,8"/>
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,0,0,16">
            <Grid Margin="20,10,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Automatic mode switching" FontSize="12.5"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Automatically select the mode based on the active application."
                               FontSize="10.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                              IsChecked="{Binding AutoSwitchEnabled}"
                              Command="{Binding ToggleAutoSwitchCommand}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Add / Edit Mode -->
        <TextBlock Text="Add mode" Style="{StaticResource GroupHeaderStyle}" Margin="4,0,0,8"/>
        <Border CornerRadius="12" Padding="20,10" Margin="0,0,0,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditing}" Value="False">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding NewModeName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsTextBoxStyle}"
                             MinWidth="0" MaxWidth="9999" Tag="Mode name" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Cancel" Cursor="Hand"
                            Command="{Binding CancelEditCommand}"
                            Margin="10,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                            FontFamily="Segoe UI Variable, Segoe UI" FontSize="11.5"
                            Foreground="{DynamicResource TextSecondaryBrush}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="14" Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding SaveModeCommand}" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Add"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEditing,
                                                RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                                <Setter Property="Text" Value="Save"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </Grid>
                <TextBox Text="{Binding NewModeAppPatterns, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SettingsTextBoxStyle}"
                         MinWidth="0" MaxWidth="9999" Tag="App patterns (comma-separated, e.g. Outlook, Teams)"
                         Margin="0,8,0,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding NewModePrompt, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SettingsTextBoxStyle}"
                         MinWidth="0" MaxWidth="9999" Tag="System prompt"
                         Margin="0,8,0,0" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="60" VerticalAlignment="Top"/>
            </StackPanel>
        </Border>

        <!-- Mode list -->
        <TextBlock Text="Active modes" Style="{StaticResource GroupHeaderStyle}" Margin="4,0,0,8"/>
        <ItemsControl ItemsSource="{Binding Modes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                            Padding="16,10" Margin="0,0,0,4" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding DataContext.EditModeCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontSize="12.5" FontFamily="Segoe UI Variable, Segoe UI"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <!-- Built-in badge -->
                                    <Border Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVisibility}}"
                                            Background="{DynamicResource BadgeBgBrush}"
                                            BorderBrush="{DynamicResource BadgeBorderBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="built-in" FontSize="10" FontFamily="Segoe UI Variable, Segoe UI"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Border>
                                    <!-- Active indicator -->
                                    <Border Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}"
                                            Background="{DynamicResource SelectedBorderBrush}"
                                            CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="active" FontSize="10" FontFamily="Segoe UI Variable, Segoe UI"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding AppPatterns}" FontSize="10.5"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                           Visibility="{Binding AppPatterns, Converter={StaticResource StringNotEmptyToVisibility}}"/>
                                <TextBlock Text="{Binding SystemPrompt}" FontSize="10.5"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="36"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- Delete button (only for custom modes) -->
                            <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBoolToVisibility}}"
                                    Command="{Binding DataContext.RemoveModeCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="6" Width="28" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource ButtonBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Info hint -->
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Margin="0,16,0,0" Padding="16,12">
            <TextBlock TextWrapping="Wrap" FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                       Foreground="{DynamicResource TextSecondaryBrush}">
                <Run FontWeight="SemiBold">How it works:</Run>
                <Run Text="Each mode has a custom system prompt that shapes how text correction works. When auto-switch is enabled, the mode is selected automatically based on which application was active when you started recording. App patterns match process names (e.g. 'Outlook', 'Code', 'Slack')."/>
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
