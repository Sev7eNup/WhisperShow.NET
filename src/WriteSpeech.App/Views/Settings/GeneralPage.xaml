<UserControl x:Class="WriteSpeech.App.Views.Settings.GeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel DataContext="{Binding General}">
        <TextBlock Text="General" Style="{StaticResource PageTitleStyle}"/>

        <TextBlock Text="Hotkeys" Style="{StaticResource GroupHeaderStyle}" Margin="4,0,0,8"/>
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="0">
            <StackPanel>
                <!-- Input method row -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Input method" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Standard (keyboard only)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowLevelHookMode}" Value="True">
                                            <Setter Property="Text" Value="Low-level hooks (keyboard + mouse)"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource PillButtonStyle}" Margin="0,0,4,0"
                                Command="{Binding SetHotkeyMethodCommand}" CommandParameter="RegisterHotKey">
                            <Button.Content>
                                <TextBlock Text="Standard">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowLevelHookMode}" Value="False">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                        <Button Style="{StaticResource PillButtonStyle}"
                                Command="{Binding SetHotkeyMethodCommand}" CommandParameter="LowLevelHook">
                            <Button.Content>
                                <TextBlock Text="Advanced">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowLevelHookMode}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Keybind shortcuts row -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Keybind shortcuts" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding HotkeyDisplayText}" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding OpenHotkeyDialogCommand}" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="Audio &amp; Language" Style="{StaticResource GroupHeaderStyle}"/>
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="0">
            <StackPanel>
                <!-- Microphone row -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Microphone" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedMicrophoneDisplay}" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding OpenMicrophoneDialogCommand}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                <!-- Language row -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Language" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedLanguageDisplay}" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding OpenLanguageDialogCommand}" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Text="Voice Activity Detection" Style="{StaticResource GroupHeaderStyle}"/>
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="0">
            <StackPanel>
                <!-- Hands-free mode toggle -->
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Hands-free mode" FontSize="12.5" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Auto-start on voice, auto-stop on silence" FontSize="11.5"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding VadEnabled}"
                                  VerticalAlignment="Center"/>
                </Grid>

                <!-- Silence duration slider (only visible when VAD enabled) -->
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"
                        Visibility="{Binding VadEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Grid Margin="20,12,20,12"
                      Visibility="{Binding VadEnabled, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Silence duration" FontSize="12.5" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0.5" Maximum="5.0" TickFrequency="0.5"
                            IsSnapToTickEnabled="True" Value="{Binding VadSilenceDuration}"
                            VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="2" FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               Text="{Binding VadSilenceDuration, StringFormat={}{0:F1}s}"/>
                </Grid>

                <!-- Sensitivity slider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"
                        Visibility="{Binding VadEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Grid Margin="20,12,20,12"
                      Visibility="{Binding VadEnabled, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sensitivity" FontSize="12.5" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0.1" Maximum="0.9" TickFrequency="0.1"
                            IsSnapToTickEnabled="True" Value="{Binding VadSensitivity}"
                            VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Grid.Column="2" FontSize="11.5" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               Text="{Binding VadSensitivity, StringFormat={}{0:F1}}"/>
                </Grid>

                <!-- VAD model download status -->
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"
                        Visibility="{Binding IsVadModelDownloading, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Margin="20,8,20,12" FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"
                           Visibility="{Binding IsVadModelDownloading, Converter={StaticResource BoolToVisibility}}"
                           Text="{Binding VadDownloadStatus}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
