<Window x:Class="WriteSpeech.App.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WriteSpeech.App.ViewModels"
        xmlns:svm="clr-namespace:WriteSpeech.App.ViewModels.Settings"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Icon="/Resources/Icons/app.ico"
        Width="700" Height="580"
        Title="WriteSpeech Setup">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/SettingsDarkTheme.xaml"/>
                <ResourceDictionary Source="/Themes/SettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Step page templates -->
            <DataTemplate x:Key="WelcomeStepTemplate">
                <StackPanel>
                    <TextBlock Text="Welcome to WriteSpeech" FontSize="18" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,6"/>
                    <TextBlock Text="Speech-to-text for your desktop. Record, transcribe, and auto-insert text anywhere."
                               FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Select your language" FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,4"/>

                    <!-- Auto-detect toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox IsChecked="{Binding IsAutoDetectLanguage, Mode=OneWay}"
                                  Command="{Binding ToggleAutoDetectCommand}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Auto-detect language" FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>

                    <!-- Language grid -->
                    <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LanguageList" ItemsSource="{Binding AvailableLanguages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,6" Margin="3"
                                            Cursor="Hand" MouseLeftButtonDown="LanguageCard_Click"
                                            Tag="{Binding Code}"
                                            Background="{DynamicResource CardBgBrush}"
                                            BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Flag}" Width="24" Height="16" Margin="0,0,6,0"
                                                   VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="TranscriptionStepTemplate">
                <StackPanel>
                    <TextBlock Text="Transcription Engine" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Text="Choose how your speech is transcribed into text."
                               FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Provider cards -->
                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <Border Tag="OpenAI" MouseLeftButtonDown="ProviderCard_Click" Cursor="Hand"
                                CornerRadius="12" Padding="12,8" Margin="0,0,6,0"
                                Background="{DynamicResource CardBgBrush}"
                                BorderThickness="2" BorderBrush="Transparent">
                            <StackPanel>
                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource SelectedBorderBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Cloud" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="OpenAI / Groq" FontSize="10"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Fast and accurate. Requires API key." FontSize="10"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Tag="Local" MouseLeftButtonDown="ProviderCard_Click" Cursor="Hand"
                                CornerRadius="12" Padding="12,8" Margin="3,0,3,0"
                                Background="{DynamicResource CardBgBrush}"
                                BorderThickness="2" BorderBrush="Transparent">
                            <StackPanel>
                                <TextBlock Text="&#xE839;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource SelectedBorderBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Local" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Whisper" FontSize="10"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Offline and private. Needs model download." FontSize="10"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Tag="Parakeet" MouseLeftButtonDown="ProviderCard_Click" Cursor="Hand"
                                CornerRadius="12" Padding="12,8" Margin="6,0,0,0"
                                Background="{DynamicResource CardBgBrush}"
                                BorderThickness="2" BorderBrush="Transparent">
                            <StackPanel>
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource SelectedBorderBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Parakeet" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="NVIDIA NeMo" FontSize="10"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="English only. Needs model download." FontSize="10"
                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- ═══ Cloud config panel ═══ -->
                    <StackPanel Visibility="{Binding Provider, Converter={StaticResource StringToVisibility}, ConverterParameter=OpenAI}">
                        <!-- Sub-provider tabs: OpenAI | Groq -->
                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="16" Padding="3" Margin="0,0,0,10"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Border Tag="OpenAI" MouseLeftButtonDown="CloudSubProviderTab_Click" Cursor="Hand"
                                        CornerRadius="14" Padding="14,5" Margin="0,0,2,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="OpenAI">
                                                    <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="OpenAI" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI Variable, Segoe UI">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="OpenAI">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <Border Tag="Groq" MouseLeftButtonDown="CloudSubProviderTab_Click" Cursor="Hand"
                                        CornerRadius="14" Padding="14,5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="Groq">
                                                    <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Groq" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI Variable, Segoe UI">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CloudTranscriptionProvider}" Value="Groq">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- OpenAI cloud config -->
                        <StackPanel Visibility="{Binding CloudTranscriptionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=OpenAI}">
                            <TextBlock Text="API Key" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="OpenAiApiKeyBox" Style="{StaticResource SettingsTextBoxStyle}"
                                     Tag="sk-..." MaxWidth="460" MinWidth="300" KeyDown="ApiKeyBox_KeyDown"/>
                            <TextBlock Text="Model" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                            <ItemsControl ItemsSource="{x:Static svm:TranscriptionSettingsViewModel.CloudTranscriptionModels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,3" Padding="10,5" Cursor="Hand"
                                                Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                                BorderThickness="2" Tag="{Binding Id}"
                                                MouseLeftButtonDown="TranscriptionModelCard_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Margin="8,0,0,0"
                                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Groq cloud config -->
                        <StackPanel Visibility="{Binding CloudTranscriptionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Groq}">
                            <TextBlock Text="API Key" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="GroqTranscriptionApiKeyBox" Style="{StaticResource SettingsTextBoxStyle}"
                                     Tag="gsk-..." MaxWidth="460" MinWidth="300" KeyDown="GroqTranscriptionApiKeyBox_KeyDown"/>
                            <TextBlock Text="Model" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                            <ItemsControl ItemsSource="{x:Static svm:TranscriptionSettingsViewModel.GroqTranscriptionModels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,3" Padding="10,5" Cursor="Hand"
                                                Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                                BorderThickness="2" Tag="{Binding Id}"
                                                MouseLeftButtonDown="TranscriptionModelCard_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Margin="8,0,0,0"
                                                           FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>

                    <!-- ═══ Local config panel ═══ -->
                    <StackPanel Visibility="{Binding Provider, Converter={StaticResource StringToVisibility}, ConverterParameter=Local}">
                        <CheckBox IsChecked="{Binding LocalGpuAcceleration, Mode=OneWay}"
                                  Command="{Binding SelectCloudTranscriptionProviderCommand}" CommandParameter="unused"
                                  Margin="0,0,0,6">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Padding="10,6" Cursor="Hand"
                                            MouseLeftButtonDown="ToggleLocalGpu_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding LocalGpuAcceleration, Mode=OneWay}" IsHitTestVisible="False"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Text="GPU Acceleration (CUDA)" FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                        <TextBlock Text="Download the transcription model in Settings &gt; Models after setup."
                                   FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- ═══ Parakeet config panel ═══ -->
                    <StackPanel Visibility="{Binding Provider, Converter={StaticResource StringToVisibility}, ConverterParameter=Parakeet}">
                        <CheckBox IsChecked="{Binding ParakeetGpuAcceleration, Mode=OneWay}"
                                  Margin="0,0,0,6">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" Padding="10,6" Cursor="Hand"
                                            MouseLeftButtonDown="ToggleParakeetGpu_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding ParakeetGpuAcceleration, Mode=OneWay}" IsHitTestVisible="False"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Text="GPU Acceleration (CUDA)" FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                        <TextBlock Text="English only. Download the model in Settings &gt; Models after setup."
                                   FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="CorrectionStepTemplate">
                <StackPanel>
                    <TextBlock Text="AI Text Correction" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Text="Optionally improve transcription quality with AI post-processing."
                               FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Correction provider pills -->
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="20" Padding="4" Margin="0,0,0,16"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- Off -->
                            <Border Tag="Off" MouseLeftButtonDown="CorrectionProviderPill_Click" Cursor="Hand"
                                    CornerRadius="16" Padding="16,6" Margin="0,0,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Off">
                                                <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Off" FontSize="11.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CorrectionProvider}" Value="Off">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <!-- OpenAI -->
                            <Border Tag="OpenAI" MouseLeftButtonDown="CorrectionProviderPill_Click" Cursor="Hand"
                                    CornerRadius="16" Padding="16,6" Margin="0,0,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="OpenAI">
                                                <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="OpenAI" FontSize="11.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CorrectionProvider}" Value="OpenAI">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <!-- Anthropic -->
                            <Border Tag="Anthropic" MouseLeftButtonDown="CorrectionProviderPill_Click" Cursor="Hand"
                                    CornerRadius="16" Padding="16,6" Margin="0,0,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Anthropic">
                                                <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Anthropic" FontSize="11.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CorrectionProvider}" Value="Anthropic">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <!-- Google -->
                            <Border Tag="Google" MouseLeftButtonDown="CorrectionProviderPill_Click" Cursor="Hand"
                                    CornerRadius="16" Padding="16,6" Margin="0,0,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Google">
                                                <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Google" FontSize="11.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CorrectionProvider}" Value="Google">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <!-- Groq -->
                            <Border Tag="Groq" MouseLeftButtonDown="CorrectionProviderPill_Click" Cursor="Hand"
                                    CornerRadius="16" Padding="16,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Groq">
                                                <Setter Property="Background" Value="{DynamicResource SelectedBorderBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Groq" FontSize="11.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CorrectionProvider}" Value="Groq">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ OpenAI correction config ═══ -->
                    <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=OpenAI}">
                        <TextBlock Text="Using your OpenAI API key from the previous step."
                                   FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"
                                   Visibility="{Binding IsReusableOpenAiKey, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="Model" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{x:Static svm:TranscriptionSettingsViewModel.CloudCorrectionModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,2" Padding="10,4" Cursor="Hand"
                                            Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                            BorderThickness="2" Tag="{Binding Id}"
                                            MouseLeftButtonDown="CorrectionModelCard_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10" Margin="8,0,0,0"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ═══ Anthropic correction config ═══ -->
                    <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Anthropic}">
                        <TextBlock Text="API Key" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="AnthropicApiKeyBox" Style="{StaticResource SettingsTextBoxStyle}"
                                 Tag="sk-ant-..." MaxWidth="460" MinWidth="300" KeyDown="AnthropicApiKeyBox_KeyDown"/>
                        <TextBlock Text="Model" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                        <ItemsControl ItemsSource="{x:Static svm:TranscriptionSettingsViewModel.AnthropicCorrectionModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,2" Padding="10,4" Cursor="Hand"
                                            Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                            BorderThickness="2" Tag="{Binding Id}"
                                            MouseLeftButtonDown="CorrectionModelCard_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10" Margin="8,0,0,0"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ═══ Google correction config ═══ -->
                    <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Google}">
                        <TextBlock Text="API Key" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="GoogleApiKeyBox" Style="{StaticResource SettingsTextBoxStyle}"
                                 Tag="AI..." MaxWidth="460" MinWidth="300" KeyDown="GoogleApiKeyBox_KeyDown"/>
                        <TextBlock Text="Model" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                        <ItemsControl ItemsSource="{x:Static svm:TranscriptionSettingsViewModel.GoogleCorrectionModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,2" Padding="10,4" Cursor="Hand"
                                            Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                            BorderThickness="2" Tag="{Binding Id}"
                                            MouseLeftButtonDown="CorrectionModelCard_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10" Margin="8,0,0,0"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ═══ Groq correction config ═══ -->
                    <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Groq}">
                        <TextBlock Text="API Key" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="GroqCorrectionApiKeyBox" Style="{StaticResource SettingsTextBoxStyle}"
                                 Tag="gsk-..." MaxWidth="460" MinWidth="300" KeyDown="GroqCorrectionApiKeyBox_KeyDown"/>
                        <TextBlock Text="Model" FontSize="11" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                        <ItemsControl ItemsSource="{x:Static svm:TranscriptionSettingsViewModel.GroqCorrectionModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,2" Padding="10,4" Cursor="Hand"
                                            Background="{DynamicResource CardBgBrush}" CornerRadius="8"
                                            BorderThickness="2" Tag="{Binding Id}"
                                            MouseLeftButtonDown="CorrectionModelCard_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10" Margin="8,0,0,0"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Info when Off -->
                    <TextBlock FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CorrectionProvider}" Value="Off">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Text" Value="You can enable AI correction later in Settings > Intelligence."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="MicrophoneStepTemplate">
                <StackPanel>
                    <TextBlock Text="Microphone" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,8,0,4"/>
                    <TextBlock Text="Select the microphone to use for recording."
                               FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="MicrophoneList" ItemsSource="{Binding AvailableMicrophones}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="16,12" Margin="0,0,0,6"
                                            Cursor="Hand" MouseLeftButtonDown="MicrophoneItem_Click"
                                            Background="{DynamicResource CardBgBrush}"
                                            BorderThickness="2" BorderBrush="Transparent">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <ProgressBar Height="4" Margin="0,8,0,0"
                                                         Minimum="0" Maximum="1"
                                                         Value="{Binding DataContext.MicTestLevel, Mode=OneWay,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                         Foreground="#4CAF50"
                                                         Background="{DynamicResource ButtonBgBrush}"
                                                         BorderThickness="0">
                                                <ProgressBar.Visibility>
                                                    <MultiBinding Converter="{StaticResource MicLevelVisibility}">
                                                        <Binding Path="DeviceIndex"/>
                                                        <Binding Path="DataContext.SelectedMicrophoneIndex"
                                                                 RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                        <Binding Path="DataContext.IsMicTesting"
                                                                 RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    </MultiBinding>
                                                </ProgressBar.Visibility>
                                                <ProgressBar.Resources>
                                                    <Style TargetType="ProgressBar">
                                                        <Style.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="2"/>
                                                            </Style>
                                                        </Style.Resources>
                                                    </Style>
                                                </ProgressBar.Resources>
                                            </ProgressBar>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Text="All set! Click Finish to start using WriteSpeech."
                               FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12">
        <Border.LayoutTransform>
            <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
        </Border.LayoutTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        <Border x:Name="ClipBorder" CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Title bar -->
                    <RowDefinition Height="Auto"/>  <!-- Progress dots -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                    <RowDefinition Height="Auto"/>  <!-- Bottom nav -->
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Grid Grid.Row="0" Height="40" Background="{DynamicResource SidebarBgBrush}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="WriteSpeech.NET" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                </Grid>

                <!-- PROGRESS INDICATOR -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,8">
                    <!-- Step 1 dot -->
                    <StackPanel>
                        <Ellipse x:Name="Dot0" Width="10" Height="10" Fill="{DynamicResource SelectedBorderBrush}"/>
                        <TextBlock Text="Language" FontSize="9" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border x:Name="Line01" Width="50" Height="2" VerticalAlignment="Top" Margin="4,4,4,0"
                            Background="{DynamicResource ButtonBgBrush}"/>
                    <!-- Step 2 dot -->
                    <StackPanel>
                        <Ellipse x:Name="Dot1" Width="10" Height="10" Fill="{DynamicResource ButtonBgBrush}"/>
                        <TextBlock Text="Engine" FontSize="9" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border x:Name="Line12" Width="50" Height="2" VerticalAlignment="Top" Margin="4,4,4,0"
                            Background="{DynamicResource ButtonBgBrush}"/>
                    <!-- Step 3 dot -->
                    <StackPanel>
                        <Ellipse x:Name="Dot2" Width="10" Height="10" Fill="{DynamicResource ButtonBgBrush}"/>
                        <TextBlock Text="AI" FontSize="9" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border x:Name="Line23" Width="50" Height="2" VerticalAlignment="Top" Margin="4,4,4,0"
                            Background="{DynamicResource ButtonBgBrush}"/>
                    <!-- Step 4 dot -->
                    <StackPanel>
                        <Ellipse x:Name="Dot3" Width="10" Height="10" Fill="{DynamicResource ButtonBgBrush}"/>
                        <TextBlock Text="Mic" FontSize="9" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- CONTENT AREA -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding}" Margin="32,0,32,0">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate" Value="{StaticResource WelcomeStepTemplate}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="Transcription">
                                        <Setter Property="ContentTemplate" Value="{StaticResource TranscriptionStepTemplate}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="Correction">
                                        <Setter Property="ContentTemplate" Value="{StaticResource CorrectionStepTemplate}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="Microphone">
                                        <Setter Property="ContentTemplate" Value="{StaticResource MicrophoneStepTemplate}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </ScrollViewer>

                <!-- BOTTOM NAVIGATION BAR -->
                <Border Grid.Row="3" Background="{DynamicResource SidebarBgBrush}"
                        Padding="24,12" CornerRadius="0,0,12,12">
                    <Grid>
                        <!-- Back button (left) -->
                        <Button Content="Back" HorizontalAlignment="Left"
                                Style="{StaticResource PillButtonStyle}"
                                Command="{Binding NavigateBackCommand}"
                                Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Next / Finish button (right) -->
                        <Button HorizontalAlignment="Right"
                                Command="{Binding NavigateNextCommand}"
                                IsEnabled="{Binding CanGoNext}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="Next"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource SelectedBorderBrush}"
                                                        CornerRadius="10" Padding="20,8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                            <Setter Property="Content" Value="Finish Setup"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
