<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors (hardcoded dark, matching overlay aesthetic) -->
    <SolidColorBrush x:Key="TrayMenuBg" Color="#FF2D2D2D"/>
    <SolidColorBrush x:Key="TrayMenuHoverBg" Color="#FF3A3A3A"/>
    <SolidColorBrush x:Key="TrayMenuAccent" Color="#FF9B7DFF"/>
    <SolidColorBrush x:Key="TrayMenuText" Color="#FFE8E8E8"/>
    <SolidColorBrush x:Key="TrayMenuTextSecondary" Color="#FF999999"/>
    <SolidColorBrush x:Key="TrayMenuDivider" Color="#FF3A3A3A"/>

    <!-- ContextMenu style -->
    <Style x:Key="TrayContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border x:Name="MenuBorder"
                            Background="{StaticResource TrayMenuBg}"
                            CornerRadius="8"
                            Padding="4,6"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                              Opacity="0.5" Direction="270"
                                              Color="#000000"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem style -->
    <Style x:Key="TrayMenuItemStyle" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TrayMenuText}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBorder"
                            Background="Transparent"
                            CornerRadius="4"
                            Margin="2,1"
                            Padding="10,7"
                            BorderThickness="2,0,0,0"
                            BorderBrush="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="IconGlyph"
                                       Grid.Column="0"
                                       Text="{TemplateBinding Tag}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{StaticResource TrayMenuTextSecondary}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              Margin="4,0,12,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{StaticResource TrayMenuHoverBg}"/>
                            <Setter TargetName="ItemBorder" Property="BorderBrush"
                                    Value="{StaticResource TrayMenuAccent}"/>
                            <Setter TargetName="IconGlyph" Property="Foreground"
                                    Value="{StaticResource TrayMenuText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem style with checkmark support -->
    <Style x:Key="TrayCheckMenuItemStyle" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TrayMenuText}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBorder"
                            Background="Transparent"
                            CornerRadius="4"
                            Margin="2,1"
                            Padding="10,7"
                            BorderThickness="2,0,0,0"
                            BorderBrush="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CheckGlyph"
                                       Grid.Column="0"
                                       Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{StaticResource TrayMenuAccent}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed"/>
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              Margin="4,0,12,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{StaticResource TrayMenuHoverBg}"/>
                            <Setter TargetName="ItemBorder" Property="BorderBrush"
                                    Value="{StaticResource TrayMenuAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Submenu parent item style (with arrow and popup) -->
    <Style x:Key="TraySubMenuItemStyle" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TrayMenuText}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="4"
                                Margin="2,1"
                                Padding="10,7"
                                BorderThickness="2,0,0,0"
                                BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="IconGlyph"
                                           Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{StaticResource TrayMenuTextSecondary}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  Margin="4,0,8,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Foreground="{StaticResource TrayMenuTextSecondary}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Right"
                               HorizontalOffset="-2"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource TrayMenuBg}"
                                    CornerRadius="8"
                                    Padding="4,6"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                                      Opacity="0.5" Direction="270"
                                                      Color="#000000"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{StaticResource TrayMenuHoverBg}"/>
                            <Setter TargetName="ItemBorder" Property="BorderBrush"
                                    Value="{StaticResource TrayMenuAccent}"/>
                            <Setter TargetName="IconGlyph" Property="Foreground"
                                    Value="{StaticResource TrayMenuText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator style -->
    <Style x:Key="TraySeparatorStyle" TargetType="Separator">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1"
                            Background="{StaticResource TrayMenuDivider}"
                            Margin="10,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
