<Window x:Class="WhisperShow.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WhisperShow.App.ViewModels"
        xmlns:views="clr-namespace:WhisperShow.App.Views"
        xmlns:models="clr-namespace:WhisperShow.Core.Models;assembly=WhisperShow.Core"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Width="700" Height="500"
        Title="WhisperShow Settings"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/SettingsLightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <!-- Pill "Change" button -->
        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                CornerRadius="14" Padding="16,6"
                                BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark button style (Save and close) -->
        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#1A1A1A"
                                CornerRadius="10" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar nav RadioButton -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="8" Padding="10,7">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="Icon"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Fill="{DynamicResource TextSecondaryBrush}"
                                      Stretch="Uniform" Width="14" Height="14"
                                      VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarActiveBrush}"/>
                                <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="6" Width="28" Height="28">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimize button style -->
        <Style x:Key="MinimizeButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="6" Width="28" Height="28">
                            <TextBlock Text="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dialog close (X) button -->
        <Style x:Key="DialogCloseStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="6" Width="32" Height="32">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style for inline editing -->
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="MaxWidth" Value="300"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="10,16,0,6"/>
        </Style>

        <!-- Page title style -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,8,0,20"/>
        </Style>

        <!-- Toggle Switch style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="10" Background="#999"
                                    Width="38" Height="20"/>
                            <Border x:Name="Knob" CornerRadius="7" Background="White"
                                    Width="14" Height="14" HorizontalAlignment="Left"
                                    Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="KnobTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#7C5CFC"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.15"
                                                             EasingFunction="{x:Null}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15"
                                                             EasingFunction="{x:Null}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group header style for System page -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="4,24,0,8"/>
        </Style>

        <!-- Value Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <views:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <views:BoolToEnabledDisabledConverter x:Key="BoolToEnabledDisabled"/>
        <views:SecondsToMinutesConverter x:Key="SecondsToMinutes"/>
        <views:ProviderToVisibilityConverter x:Key="ProviderToVisibility"/>
        <views:ModelUseVisibilityConverter x:Key="ModelUseVisibility"/>
        <views:ModelActionVisibilityConverter x:Key="ModelActionVisibility"/>
        <views:ModelDeleteVisibilityConverter x:Key="ModelDeleteVisibility"/>
        <views:StringEqualsToVisibilityConverter x:Key="StringToVisibility"/>
        <views:CapturingHotkeyTextConverter x:Key="StringToCapturingText"/>

        <!-- ==================== PAGE TEMPLATES ==================== -->

        <!-- GENERAL PAGE -->
        <DataTemplate x:Key="GeneralPageTemplate">
            <StackPanel>
                <TextBlock Text="General" Style="{StaticResource PageTitleStyle}"/>

                <!-- Single container with divider lines -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="0">

                    <StackPanel>
                        <!-- Keybind shortcuts row -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Keybind shortcuts" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding HotkeyDisplayText}" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding OpenHotkeyDialogCommand}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Microphone row -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Microphone" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedMicrophoneDisplay}" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding OpenMicrophoneDialogCommand}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Language row -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Language" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedLanguageDisplay}" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding OpenLanguageDialogCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- SYSTEM PAGE -->
        <DataTemplate x:Key="SystemPageTemplate">
            <StackPanel>
                <TextBlock Text="System" Style="{StaticResource PageTitleStyle}"/>

                <!-- ===== App settings group ===== -->
                <TextBlock Text="App settings" Style="{StaticResource GroupHeaderStyle}" Margin="4,0,0,8"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- Launch app at login -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Launch app at login" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding LaunchAtLogin}"
                                          Command="{Binding ToggleLaunchAtLoginCommand}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Show overlay at all times -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Show overlay at all times" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding OverlayAlwaysVisible}"
                                          Command="{Binding ToggleOverlayAlwaysVisibleCommand}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Show app in taskbar -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Show app in taskbar" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding ShowInTaskbar}"
                                          Command="{Binding ToggleShowInTaskbarCommand}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Dark mode -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dark mode" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding IsDarkMode}"
                                          Command="{Binding ToggleDarkModeCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Sound group ===== -->
                <TextBlock Text="Sound" Style="{StaticResource GroupHeaderStyle}"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- Dictation sound effects -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dictation sound effects" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding SoundEffectsEnabled}"
                                          Command="{Binding ToggleSoundEffectsCommand}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Mute music while dictating -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mute music while dictating" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding MuteWhileDictating}"
                                          Command="{Binding ToggleMuteWhileDictatingCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Recording settings group ===== -->
                <TextBlock Text="Recording" Style="{StaticResource GroupHeaderStyle}"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- Audio compression -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Audio compression" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding AudioCompressionEnabled}"
                                          Command="{Binding ToggleAudioCompressionCommand}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Auto-dismiss -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingAutoDismiss, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="Auto-dismiss overlay" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="12" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                                    <Run Text="{Binding AutoDismissSeconds, Mode=OneWay}"/>
                                    <Run Text="seconds"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingAutoDismiss, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding AutoDismissSeconds}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="AutoDismissTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding StartEditingAutoDismissCommand}" VerticalAlignment="Center"
                                    Visibility="{Binding IsEditingAutoDismiss, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <!-- Max recording duration -->
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingMaxRecording, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="Max recording duration" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="12" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                                    <Run Text="{Binding MaxRecordingSeconds, Mode=OneWay, Converter={StaticResource SecondsToMinutes}}"/>
                                    <Run Text="minutes"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingMaxRecording, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding MaxRecordingSeconds}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="MaxRecordingTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding StartEditingMaxRecordingCommand}" VerticalAlignment="Center"
                                    Visibility="{Binding IsEditingMaxRecording, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </DataTemplate>

        <!-- DICTIONARY PAGE -->
        <DataTemplate x:Key="DictionaryPageTemplate">
            <StackPanel>
                <TextBlock Text="Custom Dictionary" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Add custom words, names, and technical terms to improve transcription accuracy."
                           FontSize="12" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Add word input -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewDictionaryWord, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBoxStyle}"
                                 MinWidth="0" MaxWidth="9999" KeyDown="DictionaryTextBox_KeyDown"
                                 VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Add" Style="{StaticResource PillButtonStyle}"
                                Command="{Binding AddDictionaryEntryCommand}" Margin="10,0,0,0"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Word list -->
                <ItemsControl ItemsSource="{Binding DictionaryEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                    Padding="16,10" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding}" FontSize="13" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                            Command="{Binding DataContext.RemoveDictionaryEntryCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        CornerRadius="6" Width="28" Height="28">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource ButtonBgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <!-- SNIPPETS PAGE -->
        <DataTemplate x:Key="SnippetsPageTemplate">
            <StackPanel>
                <TextBlock Text="Snippets" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Define keywords that automatically expand into text blocks during transcription."
                           FontSize="12" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Add snippet input -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,14" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewSnippetTrigger, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsTextBoxStyle}"
                                     MinWidth="0" MaxWidth="9999" KeyDown="SnippetTriggerTextBox_KeyDown"
                                     Tag="Keyword" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Add" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding AddSnippetCommand}" Margin="10,0,0,0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                        <TextBox Text="{Binding NewSnippetReplacement, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBoxStyle}"
                                 MinWidth="0" MaxWidth="9999" KeyDown="SnippetReplacementTextBox_KeyDown"
                                 Tag="Replacement text" Margin="0,8,0,0" AcceptsReturn="True"
                                 TextWrapping="Wrap" MinHeight="60" VerticalAlignment="Top"/>
                    </StackPanel>
                </Border>

                <!-- Snippet list -->
                <ItemsControl ItemsSource="{Binding SnippetItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                    Padding="16,10" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Trigger}" FontSize="13" FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Replacement}" FontSize="11" FontFamily="Segoe UI"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxHeight="40"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                            Command="{Binding DataContext.RemoveSnippetCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        CornerRadius="6" Width="28" Height="28">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource ButtonBgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <!-- MODELS PAGE -->
        <DataTemplate x:Key="ModelsPageTemplate">
            <StackPanel>
                <TextBlock Text="Models" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Choose your transcription provider and configure model settings."
                           FontSize="12" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Provider picker cards -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cloud card -->
                    <Border Grid.Column="0" Tag="OpenAI" MouseLeftButtonDown="ProviderCard_Click"
                            Cursor="Hand" BorderThickness="2"
                            Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Provider}" Value="OpenAI">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Cloud" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="OpenAI Whisper API" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource SelectedBorderBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}"/>
                        </Grid>
                    </Border>

                    <!-- Local card -->
                    <Border Grid.Column="2" Tag="Local" MouseLeftButtonDown="ProviderCard_Click"
                            Cursor="Hand" BorderThickness="2"
                            Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Provider}" Value="Local">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Local" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="On-device processing" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource SelectedBorderBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=Local}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===== Cloud settings (visible when Provider=OpenAI) ===== -->
                <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}">
                    <TextBlock Text="Cloud settings" Style="{StaticResource GroupHeaderStyle}"/>
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                        <StackPanel>
                            <!-- API Key -->
                            <Grid Margin="20,14,20,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Visibility="{Binding IsEditingApiKey, Converter={StaticResource InverseBoolToVisibility}}">
                                    <TextBlock Text="API Key" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding OpenAiApiKeyDisplay}" FontSize="12"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBox Visibility="{Binding IsEditingApiKey, Converter={StaticResource BoolToVisibility}}"
                                         Text="{Binding OpenAiApiKey}" Style="{StaticResource SettingsTextBoxStyle}"
                                         KeyDown="ApiKeyTextBox_KeyDown" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                        Command="{Binding StartEditingApiKeyCommand}" VerticalAlignment="Center"
                                        Visibility="{Binding IsEditingApiKey, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                            <!-- Endpoint -->
                            <Grid Margin="20,14,20,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Visibility="{Binding IsEditingEndpoint, Converter={StaticResource InverseBoolToVisibility}}">
                                    <TextBlock Text="API Endpoint" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                                        <TextBlock.Text>
                                            <Binding Path="OpenAiEndpoint" FallbackValue="Default (api.openai.com)">
                                                <Binding.TargetNullValue>Default (api.openai.com)</Binding.TargetNullValue>
                                            </Binding>
                                        </TextBlock.Text>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OpenAiEndpoint}" Value="">
                                                        <Setter Property="Text" Value="Default (api.openai.com)"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBox Visibility="{Binding IsEditingEndpoint, Converter={StaticResource BoolToVisibility}}"
                                         Text="{Binding OpenAiEndpoint}" Style="{StaticResource SettingsTextBoxStyle}"
                                         KeyDown="EndpointTextBox_KeyDown" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                        Command="{Binding StartEditingEndpointCommand}" VerticalAlignment="Center"
                                        Visibility="{Binding IsEditingEndpoint, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                            <!-- Model -->
                            <Grid Margin="20,14,20,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Visibility="{Binding IsEditingModel, Converter={StaticResource InverseBoolToVisibility}}">
                                    <TextBlock Text="Model" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding TranscriptionModel}" FontSize="12"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBox Visibility="{Binding IsEditingModel, Converter={StaticResource BoolToVisibility}}"
                                         Text="{Binding TranscriptionModel}" Style="{StaticResource SettingsTextBoxStyle}"
                                         KeyDown="ModelTextBox_KeyDown" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                        Command="{Binding StartEditingModelCommand}" VerticalAlignment="Center"
                                        Visibility="{Binding IsEditingModel, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ===== Local settings (visible when Provider=Local) ===== -->
                <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=Local}">
                    <TextBlock Text="Local settings" Style="{StaticResource GroupHeaderStyle}"/>
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                        <StackPanel>
                            <!-- GPU acceleration -->
                            <Grid Margin="20,14,20,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="GPU acceleration" FontSize="13" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding GpuAcceleration}"
                                              Command="{Binding ToggleGpuAccelerationCommand}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Available models -->
                    <TextBlock Text="Available models" Style="{StaticResource GroupHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding ModelItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12"
                                        Padding="20,14" Margin="0,0,0,8" BorderThickness="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <!-- Download button (!IsDownloaded && !IsDownloading) -->
                                            <Button Grid.Column="1" Content="Download" Cursor="Hand"
                                                    FontSize="12" FontFamily="Segoe UI"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DownloadModelCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Visibility>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <views:ModelActionVisibilityConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="IsDownloaded"/>
                                                        <Binding Path="IsDownloading"/>
                                                    </MultiBinding>
                                                </Button.Visibility>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                                CornerRadius="10" Padding="14,6"
                                                                BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Use button (IsDownloaded && !IsActive && !IsDownloading) -->
                                            <Button Grid.Column="1" Content="Use" Cursor="Hand"
                                                    FontSize="12" FontFamily="Segoe UI"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ActivateModelCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Visibility>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <views:ModelUseVisibilityConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="IsDownloaded"/>
                                                        <Binding Path="IsDownloading"/>
                                                        <Binding Path="IsActive"/>
                                                    </MultiBinding>
                                                </Button.Visibility>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="#7C5CFC"
                                                                CornerRadius="10" Padding="14,6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Foreground>
                                                    <SolidColorBrush Color="White"/>
                                                </Button.Foreground>
                                            </Button>

                                            <!-- Delete button (IsDownloaded && !IsActive && !IsDownloading) -->
                                            <Button Grid.Column="2" Content="Delete" Cursor="Hand"
                                                    FontSize="12" FontFamily="Segoe UI"
                                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                                    Command="{Binding DataContext.DeleteModelCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Visibility>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <views:ModelDeleteVisibilityConverter/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="IsDownloaded"/>
                                                        <Binding Path="IsDownloading"/>
                                                        <Binding Path="IsActive"/>
                                                    </MultiBinding>
                                                </Button.Visibility>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                                CornerRadius="10" Padding="14,6"
                                                                BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Progress bar -->
                                        <ProgressBar Grid.Row="1" Minimum="0" Maximum="1"
                                                     Value="{Binding DownloadProgress}"
                                                     Height="4" Margin="0,8,0,0"
                                                     Foreground="#7C5CFC"
                                                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ===== Text Correction section ===== -->
                <TextBlock Text="Text Correction" Style="{StaticResource GroupHeaderStyle}" Margin="0,20,0,8"/>

                <!-- Correction provider picker: Off / Cloud / Local -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Off card -->
                    <Border Grid.Column="0" Tag="Off" MouseLeftButtonDown="CorrectionProviderCard_Click"
                            Cursor="Hand" BorderThickness="2"
                            Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CorrectionProvider}" Value="Off">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <TextBlock Text="Off" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SelectedBorderBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Off}"/>
                        </Grid>
                    </Border>

                    <!-- Cloud card -->
                    <Border Grid.Column="2" Tag="Cloud" MouseLeftButtonDown="CorrectionProviderCard_Click"
                            Cursor="Hand" BorderThickness="2"
                            Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CorrectionProvider}" Value="Cloud">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Cloud" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="OpenAI" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SelectedBorderBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Cloud}"/>
                        </Grid>
                    </Border>

                    <!-- Local card -->
                    <Border Grid.Column="4" Tag="Local" MouseLeftButtonDown="CorrectionProviderCard_Click"
                            Cursor="Hand" BorderThickness="2"
                            Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CorrectionProvider}" Value="Local">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Local" FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="LLM" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource SelectedBorderBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Local}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Cloud correction settings -->
                <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Cloud}"
                            Margin="0,8,0,0">
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                        <Grid Margin="20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Visibility="{Binding IsEditingCorrectionModel, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="Model" FontSize="13" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CorrectionCloudModel}" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBox Visibility="{Binding IsEditingCorrectionModel, Converter={StaticResource BoolToVisibility}}"
                                     Text="{Binding CorrectionCloudModel}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="CorrectionModelTextBox_KeyDown" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                    Command="{Binding StartEditingCorrectionModelCommand}" VerticalAlignment="Center"
                                    Visibility="{Binding IsEditingCorrectionModel, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Local correction settings -->
                <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Local}"
                            Margin="0,8,0,0">
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GPU acceleration" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="{Binding CorrectionGpuAcceleration}"
                                          Command="{Binding ToggleCorrectionGpuAccelerationCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Correction model list -->
                    <ItemsControl ItemsSource="{Binding CorrectionModelItems}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="16,12"
                                        Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                        BorderThickness="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding SizeDisplay}" FontSize="12" Margin="8,0,0,0"
                                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <!-- Download -->
                                        <Button Grid.Column="1" Content="Download" Cursor="Hand"
                                                FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DownloadCorrectionModelCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource ModelActionVisibility}">
                                                    <Binding Path="IsDownloaded"/>
                                                    <Binding Path="IsDownloading"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{DynamicResource CardBgBrush}"
                                                            CornerRadius="10" Padding="14,6"
                                                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Use -->
                                        <Button Grid.Column="1" Content="Use" Cursor="Hand"
                                                FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="10,0,0,0"
                                                Command="{Binding DataContext.ActivateCorrectionModelCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource ModelUseVisibility}">
                                                    <Binding Path="IsDownloaded"/>
                                                    <Binding Path="IsDownloading"/>
                                                    <Binding Path="IsActive"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="#7C5CFC" CornerRadius="10" Padding="14,6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Button.Foreground><SolidColorBrush Color="White"/></Button.Foreground>
                                        </Button>
                                        <!-- Delete -->
                                        <Button Grid.Column="2" Content="Delete" Cursor="Hand"
                                                FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="6,0,0,0"
                                                Command="{Binding DataContext.DeleteCorrectionModelCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Visibility>
                                                <MultiBinding Converter="{StaticResource ModelDeleteVisibility}">
                                                    <Binding Path="IsDownloaded"/>
                                                    <Binding Path="IsDownloading"/>
                                                    <Binding Path="IsActive"/>
                                                </MultiBinding>
                                            </Button.Visibility>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{DynamicResource CardBgBrush}"
                                                            CornerRadius="10" Padding="14,6"
                                                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Progress bar -->
                                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Minimum="0" Maximum="1"
                                                     Value="{Binding DownloadProgress}" Height="4" Margin="0,8,0,0"
                                                     Foreground="#7C5CFC"
                                                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ===== Combined Audio Model section (only for Cloud provider) ===== -->
                <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}">
                <TextBlock Text="Combined Audio Model" Style="{StaticResource GroupHeaderStyle}" Margin="0,20,0,8"/>
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <Grid Margin="16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#x2139;" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Top" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="11" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Sends audio directly to OpenAI for transcription + correction in a single API call. Requires an API key."/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                        <Grid Margin="20,14,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Combined audio model" FontSize="13" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding CombinedAudioModel}" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,3,0,0"
                                           Visibility="{Binding UseCombinedAudioModel, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Change" Style="{StaticResource PillButtonStyle}"
                                        Command="{Binding StartEditingCombinedAudioModelCommand}"
                                        VerticalAlignment="Center" Margin="0,0,10,0"
                                        Visibility="{Binding UseCombinedAudioModel, Converter={StaticResource BoolToVisibility}}"/>
                                <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding UseCombinedAudioModel}"
                                              Command="{Binding ToggleCombinedAudioModelCommand}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="20,0,20,14"
                              Visibility="{Binding IsEditingCombinedAudioModel, Converter={StaticResource BoolToVisibility}}">
                            <TextBox Text="{Binding CombinedAudioModel}" Style="{StaticResource SettingsTextBoxStyle}"
                                     KeyDown="CombinedAudioModelTextBox_KeyDown"/>
                        </Grid>
                    </StackPanel>
                </Border>
                </StackPanel>

                <!-- Cloud usage hint -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,10,0,0"
                        Visibility="{Binding ShowCloudUsageHint, Converter={StaticResource BoolToVisibility}}">
                    <Grid Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#x2139;" FontSize="16" Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Top" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Cloud text correction requires an OpenAI API key. Configure it above in the Transcription → Cloud section."/>
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- STATISTICS PAGE -->
        <DataTemplate x:Key="StatisticsPageTemplate">
            <StackPanel>
                <TextBlock Text="Statistics" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Usage statistics for your transcription sessions."
                           FontSize="12" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Stats cards -->
                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                    <StackPanel>
                        <!-- Total transcriptions -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total transcriptions" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalTranscriptions}" FontSize="18"
                                       FontWeight="Bold" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Total recording time -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total recording time" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalRecordingTimeDisplay}" FontSize="18"
                                       FontWeight="Bold" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Average duration -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Average duration" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding AverageDurationDisplay}" FontSize="18"
                                       FontWeight="Bold" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Estimated API cost -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Estimated API cost" FontSize="13" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Based on $0.006/min (Whisper API)" FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding EstimatedCostDisplay}" FontSize="18"
                                       FontWeight="Bold" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Errors -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Errors" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ErrorCount}" FontSize="18"
                                       FontWeight="Bold" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>

                        <!-- Provider breakdown -->
                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="By provider" FontSize="13" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProviderBreakdownDisplay}" FontSize="13"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Refresh" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding RefreshStatsCommand}" Margin="0,0,10,0"/>
                    <Button Content="Reset all" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding ResetStatsCommand}"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        </ResourceDictionary>
    </Window.Resources>

    <!-- Root: main content + dialog overlay -->
    <Border CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
        </Border.Effect>
        <Border x:Name="ClipBorder" CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <!-- Main layout -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Grid Grid.Row="0" Height="40" Background="{DynamicResource SidebarBgBrush}"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="WhisperShow.net" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button Style="{StaticResource MinimizeButtonStyle}" Click="MinimizeButton_Click"/>
                        <Button Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- SIDEBAR + CONTENT -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR -->
                    <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}" CornerRadius="0,0,0,12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="16,0,0,14">
                                <TextBlock Text="{Binding VersionText}" FontSize="10" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="8,8,8,0">
                            <TextBlock Text="SETTINGS" Style="{StaticResource SectionHeaderStyle}"/>
                            <RadioButton Style="{StaticResource NavItemStyle}" Content="General"
                                         IsChecked="True" GroupName="Nav"
                                         Tag="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="{x:Static vm:SettingsPage.General}"/>
                            <RadioButton Style="{StaticResource NavItemStyle}" Content="System" GroupName="Nav"
                                         Tag="M4,6H20V16H4M20,18A2,2 0 0,0 22,16V6C22,4.89 21.1,4 20,4H4C2.89,4 2,4.89 2,6V16A2,2 0 0,0 4,18H0V20H24V18H20Z"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="{x:Static vm:SettingsPage.System}"/>
                            <TextBlock Text="PROVIDER" Style="{StaticResource SectionHeaderStyle}"/>
                            <RadioButton Style="{StaticResource NavItemStyle}" Content="Models" GroupName="Nav"
                                         Tag="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L5,8.09V15.91L12,19.85L19,15.91V8.09L12,4.15Z"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="{x:Static vm:SettingsPage.Models}"/>
                            <TextBlock Text="AI" Style="{StaticResource SectionHeaderStyle}"/>
                            <RadioButton Style="{StaticResource NavItemStyle}" Content="Dictionary" GroupName="Nav"
                                         Tag="M5,4V7H10.5V19H13.5V7H19V4H5Z"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="{x:Static vm:SettingsPage.Dictionary}"/>
                            <RadioButton Style="{StaticResource NavItemStyle}" Content="Snippets" GroupName="Nav"
                                         Tag="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M9,13V15H15V13H9M9,17V19H13V17H9Z"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="{x:Static vm:SettingsPage.Snippets}"/>
                            <TextBlock Text="DATA" Style="{StaticResource SectionHeaderStyle}"/>
                            <RadioButton Style="{StaticResource NavItemStyle}" Content="Statistics" GroupName="Nav"
                                         Tag="M19,3H5C3.9,3 3,3.9 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M9,17H7V10H9V17M13,17H11V7H13V17M17,17H15V13H17V17Z"
                                         Command="{Binding NavigateCommand}"
                                         CommandParameter="{x:Static vm:SettingsPage.Statistics}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                    <!-- RIGHT CONTENT -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl Content="{Binding}" Margin="28,8,28,20">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource GeneralPageTemplate}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="System">
                                            <Setter Property="ContentTemplate" Value="{StaticResource SystemPageTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="Models">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ModelsPageTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="Dictionary">
                                            <Setter Property="ContentTemplate" Value="{StaticResource DictionaryPageTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="Snippets">
                                            <Setter Property="ContentTemplate" Value="{StaticResource SnippetsPageTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedPage}" Value="Statistics">
                                            <Setter Property="ContentTemplate" Value="{StaticResource StatisticsPageTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ==================== DIALOG OVERLAY ==================== -->
            <Grid x:Name="DialogOverlay"
                  Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibility}}">
                <!-- Dim background -->
                <Border Background="{DynamicResource OverlayBrush}" MouseLeftButtonDown="DialogOverlay_Click"/>

                <!-- Dialog card -->
                <Border Background="{DynamicResource DialogBgBrush}" CornerRadius="16"
                        MaxWidth="480" MinWidth="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2"/>
                    </Border.Effect>

                    <Grid>
                        <!-- HOTKEY DIALOG -->
                        <StackPanel Visibility="{Binding ActiveDialog, Converter={StaticResource StringToVisibility}, ConverterParameter=Hotkey}"
                                    Margin="28,24,28,28">
                            <!-- Header -->
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Keybind shortcuts" FontSize="18" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Button Style="{StaticResource DialogCloseStyle}" HorizontalAlignment="Right"
                                        Command="{Binding CloseDialogCommand}" Margin="0,-4,-4,0"/>
                            </Grid>

                            <!-- TOGGLE SECTION -->
                            <TextBlock Text="Toggle mode" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Press to start and stop dictation" FontSize="12"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,10"/>

                            <ItemsControl ItemsSource="{Binding ToggleBadges}" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BadgeBgBrush}"
                                                BorderBrush="{DynamicResource BadgeBorderBrush}"
                                                BorderThickness="1" CornerRadius="5"
                                                Padding="10,5" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding}" FontSize="12" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                    Padding="14,10" Margin="0,0,0,16" Cursor="Hand"
                                    MouseLeftButtonDown="RebindToggle_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource BadgeBgBrush}"
                                            BorderBrush="{DynamicResource BadgeBorderBrush}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,3" Margin="0,0,10,0">
                                        <TextBlock Text="enter" FontSize="11" FontFamily="Segoe UI"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                    <TextBlock FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="CapturingHotkey"
                                                     Converter="{StaticResource StringToCapturingText}"
                                                     ConverterParameter="Toggle"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Divider -->
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,0,0,16"/>

                            <!-- PUSH-TO-TALK SECTION -->
                            <TextBlock Text="Push to Talk" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Hold to speak, release to stop" FontSize="12"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,10"/>

                            <ItemsControl ItemsSource="{Binding PttBadges}" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BadgeBgBrush}"
                                                BorderBrush="{DynamicResource BadgeBorderBrush}"
                                                BorderThickness="1" CornerRadius="5"
                                                Padding="10,5" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding}" FontSize="12" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                    Padding="14,10" Margin="0,0,0,16" Cursor="Hand"
                                    MouseLeftButtonDown="RebindPtt_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource BadgeBgBrush}"
                                            BorderBrush="{DynamicResource BadgeBorderBrush}"
                                            BorderThickness="1" CornerRadius="5" Padding="8,3" Margin="0,0,10,0">
                                        <TextBlock Text="enter" FontSize="11" FontFamily="Segoe UI"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                    <TextBlock FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="CapturingHotkey"
                                                     Converter="{StaticResource StringToCapturingText}"
                                                     ConverterParameter="PushToTalk"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Reset to default -->
                            <Button Content="Reset to default" Style="{StaticResource PillButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Command="{Binding ResetHotkeyToDefaultCommand}"/>
                        </StackPanel>

                        <!-- MICROPHONE DIALOG -->
                        <StackPanel Visibility="{Binding ActiveDialog, Converter={StaticResource StringToVisibility}, ConverterParameter=Microphone}"
                                    Margin="28,24,28,28">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Microphone" FontSize="18" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Button Style="{StaticResource DialogCloseStyle}" HorizontalAlignment="Right"
                                        Command="{Binding CloseDialogCommand}" Margin="0,-4,-4,0"/>
                            </Grid>

                            <ItemsControl x:Name="MicrophoneList" ItemsSource="{Binding AvailableMicrophones}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="MicBorder" CornerRadius="10" Padding="16,12" Margin="0,0,0,6"
                                                Cursor="Hand" MouseLeftButtonDown="MicrophoneItem_Click"
                                                Background="{DynamicResource CardBgBrush}"
                                                BorderThickness="2" BorderBrush="Transparent">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- LANGUAGE DIALOG -->
                        <StackPanel Visibility="{Binding ActiveDialog, Converter={StaticResource StringToVisibility}, ConverterParameter=Language}"
                                    Margin="28,24,28,28">
                            <!-- Header with Auto-detect toggle -->
                            <Grid Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="Languages" FontSize="18" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Select your language" FontSize="12"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="Auto-detect" FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <CheckBox IsChecked="{Binding IsAutoDetectLanguage, Mode=OneWay}"
                                              Command="{Binding ToggleAutoDetectLanguageCommand}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Style="{StaticResource DialogCloseStyle}" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Margin="0,-4,30,0"
                                        Command="{Binding CloseDialogCommand}"
                                        Visibility="Collapsed"/>
                            </Grid>

                            <!-- Language grid -->
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,12,0,16">
                                <ItemsControl x:Name="LanguageList" ItemsSource="{Binding AvailableLanguages}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="10,8" Margin="3"
                                                    Cursor="Hand" MouseLeftButtonDown="LanguageCard_Click"
                                                    Tag="{Binding Code}"
                                                    Background="{DynamicResource CardBgBrush}"
                                                    BorderThickness="2" BorderBrush="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Flag}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" FontFamily="Segoe UI"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Save and close -->
                            <Button Content="Save and close" Style="{StaticResource DarkButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Command="{Binding SaveAndCloseLanguageCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        </Border>
    </Border>
</Window>
