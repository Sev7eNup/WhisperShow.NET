<UserControl x:Class="WhisperShow.App.Views.Settings.SnippetsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel DataContext="{Binding DictionarySnippets}">
        <TextBlock Text="Snippets" Style="{StaticResource PageTitleStyle}"/>
        <TextBlock Text="Define keywords that automatically expand into text blocks during transcription."
                   FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <!-- Add / Edit snippet input -->
        <Border CornerRadius="12" Padding="20,14" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditingSnippet}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditingSnippet}" Value="False">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding NewSnippetTrigger, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsTextBoxStyle}"
                             MinWidth="0" MaxWidth="9999" KeyDown="SnippetTriggerTextBox_KeyDown"
                             Tag="Keyword" VerticalAlignment="Center"/>
                    <!-- Cancel button (only visible in edit mode) -->
                    <Button Grid.Column="1" Content="Cancel" Cursor="Hand"
                            Command="{Binding CancelEditSnippetCommand}"
                            Margin="10,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsEditingSnippet, Converter={StaticResource BoolToVisibility}}"
                            FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="14" Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Add / Save button -->
                    <Button Grid.Column="2" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding SaveSnippetCommand}" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Add"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsEditingSnippet,
                                                RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                                <Setter Property="Text" Value="Save"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </Grid>
                <TextBox Text="{Binding NewSnippetReplacement, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SettingsTextBoxStyle}"
                         MinWidth="0" MaxWidth="9999" KeyDown="SnippetReplacementTextBox_KeyDown"
                         Tag="Replacement text" Margin="0,8,0,0" AcceptsReturn="True"
                         TextWrapping="Wrap" MinHeight="60" VerticalAlignment="Top"/>
            </StackPanel>
        </Border>

        <!-- Snippet list -->
        <ItemsControl ItemsSource="{Binding SnippetItems}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                            Padding="16,10" Margin="0,0,0,4" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding DataContext.EditSnippetCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Trigger}" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Replacement}" FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="40"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Command="{Binding DataContext.RemoveSnippetCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="6" Width="28" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource ButtonBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
