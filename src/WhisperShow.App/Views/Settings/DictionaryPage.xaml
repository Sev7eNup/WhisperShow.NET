<UserControl x:Class="WhisperShow.App.Views.Settings.DictionaryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel DataContext="{Binding DictionarySnippets}">
        <TextBlock Text="Custom Dictionary" Style="{StaticResource PageTitleStyle}"/>
        <TextBlock Text="Add custom words, names, and technical terms to improve transcription accuracy."
                   FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <!-- Add word input -->
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding NewDictionaryWord, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SettingsTextBoxStyle}"
                         MinWidth="0" MaxWidth="9999" KeyDown="DictionaryTextBox_KeyDown"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Add" Style="{StaticResource PillButtonStyle}"
                        Command="{Binding AddDictionaryEntryCommand}" Margin="10,0,0,0"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Word list -->
        <ItemsControl ItemsSource="{Binding DictionaryEntries}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                            Padding="16,10" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding}" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="10" Cursor="Hand" VerticalAlignment="Center"
                                    Command="{Binding DataContext.RemoveDictionaryEntryCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="6" Width="28" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource ButtonBgBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
