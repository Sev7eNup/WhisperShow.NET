<UserControl x:Class="WhisperShow.App.Views.Settings.ModelsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WhisperShow.App.Converters">
    <StackPanel DataContext="{Binding Transcription}">
        <TextBlock Text="Models" Style="{StaticResource PageTitleStyle}"/>
        <TextBlock Text="Choose your transcription provider and configure model settings."
                   FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <!-- Provider picker cards -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Cloud card -->
            <Border Grid.Column="0" Tag="OpenAI" MouseLeftButtonDown="ProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="OpenAI">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Cloud" FontSize="14" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="OpenAI Whisper API" FontSize="12"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}"/>
                </Grid>
            </Border>

            <!-- Local card -->
            <Border Grid.Column="2" Tag="Local" MouseLeftButtonDown="ProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="20,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="Local">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="&#xE770;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Local" FontSize="14" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="On-device processing" FontSize="12"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=Local}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Cloud settings (visible when Provider=OpenAI) ===== -->
        <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}">
            <TextBlock Text="Cloud settings" Style="{StaticResource GroupHeaderStyle}"/>
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                <StackPanel>
                    <!-- API Key -->
                    <Grid Margin="20,14,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Visibility="{Binding IsEditingApiKey, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="API Key" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding OpenAiApiKeyDisplay}" FontSize="12"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <TextBox Visibility="{Binding IsEditingApiKey, Converter={StaticResource BoolToVisibility}}"
                                 Text="{Binding OpenAiApiKey}" Style="{StaticResource SettingsTextBoxStyle}"
                                 KeyDown="ApiKeyTextBox_KeyDown" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                Command="{Binding StartEditingApiKeyCommand}" VerticalAlignment="Center"
                                Visibility="{Binding IsEditingApiKey, Converter={StaticResource InverseBoolToVisibility}}"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                    <!-- Endpoint -->
                    <Grid Margin="20,14,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Visibility="{Binding IsEditingEndpoint, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="API Endpoint" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">
                                <TextBlock.Text>
                                    <Binding Path="OpenAiEndpoint" FallbackValue="Default (api.openai.com)">
                                        <Binding.TargetNullValue>Default (api.openai.com)</Binding.TargetNullValue>
                                    </Binding>
                                </TextBlock.Text>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenAiEndpoint}" Value="">
                                                <Setter Property="Text" Value="Default (api.openai.com)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBox Visibility="{Binding IsEditingEndpoint, Converter={StaticResource BoolToVisibility}}"
                                 Text="{Binding OpenAiEndpoint}" Style="{StaticResource SettingsTextBoxStyle}"
                                 KeyDown="EndpointTextBox_KeyDown" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                Command="{Binding StartEditingEndpointCommand}" VerticalAlignment="Center"
                                Visibility="{Binding IsEditingEndpoint, Converter={StaticResource InverseBoolToVisibility}}"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                    <!-- Model -->
                    <Grid Margin="20,14,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Visibility="{Binding IsEditingModel, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="Model" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding TranscriptionModel}" FontSize="12"
                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <TextBox Visibility="{Binding IsEditingModel, Converter={StaticResource BoolToVisibility}}"
                                 Text="{Binding TranscriptionModel}" Style="{StaticResource SettingsTextBoxStyle}"
                                 KeyDown="ModelTextBox_KeyDown" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                                Command="{Binding StartEditingModelCommand}" VerticalAlignment="Center"
                                Visibility="{Binding IsEditingModel, Converter={StaticResource InverseBoolToVisibility}}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== Local settings (visible when Provider=Local) ===== -->
        <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=Local}">
            <TextBlock Text="Local settings" Style="{StaticResource GroupHeaderStyle}"/>
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                <StackPanel>
                    <!-- GPU acceleration -->
                    <Grid Margin="20,14,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GPU acceleration" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding GpuAcceleration}"
                                      Command="{Binding ToggleGpuAccelerationCommand}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Available models -->
            <TextBlock Text="Available models" Style="{StaticResource GroupHeaderStyle}"/>
            <ItemsControl ItemsSource="{Binding Models.ModelItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12"
                                Padding="20,14" Margin="0,0,0,8" BorderThickness="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="12"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <!-- Download button (!IsDownloaded && !IsDownloading) -->
                                    <Button Grid.Column="1" Content="Download" Cursor="Hand"
                                            FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Models.DownloadModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelActionVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="10" Padding="14,6"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Use button (IsDownloaded && !IsActive && !IsDownloading) -->
                                    <Button Grid.Column="1" Content="Use" Cursor="Hand"
                                            FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Models.ActivateModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelUseVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                                <Binding Path="IsActive"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#7C5CFC"
                                                        CornerRadius="10" Padding="14,6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </Button.Foreground>
                                    </Button>

                                    <!-- Delete button (IsDownloaded && !IsActive && !IsDownloading) -->
                                    <Button Grid.Column="2" Content="Delete" Cursor="Hand"
                                            FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                                            VerticalAlignment="Center" Margin="6,0,0,0"
                                            Command="{Binding DataContext.Models.DeleteModelCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <converters:ModelDeleteVisibilityConverter/>
                                                </MultiBinding.Converter>
                                                <Binding Path="IsDownloaded"/>
                                                <Binding Path="IsDownloading"/>
                                                <Binding Path="IsActive"/>
                                            </MultiBinding>
                                        </Button.Visibility>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource ButtonBgBrush}"
                                                        CornerRadius="10" Padding="14,6"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Progress bar -->
                                <ProgressBar Grid.Row="1" Minimum="0" Maximum="1"
                                             Value="{Binding DownloadProgress}"
                                             Height="4" Margin="0,8,0,0"
                                             Foreground="#7C5CFC"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- ===== Text Correction section ===== -->
        <TextBlock Text="Text Correction" Style="{StaticResource GroupHeaderStyle}" Margin="0,20,0,8"/>

        <!-- Correction provider picker: Off / Cloud / Local -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Off card -->
            <Border Grid.Column="0" Tag="Off" MouseLeftButtonDown="CorrectionProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Off">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock Text="Off" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Off}"/>
                </Grid>
            </Border>

            <!-- Cloud card -->
            <Border Grid.Column="2" Tag="Cloud" MouseLeftButtonDown="CorrectionProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Cloud">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Cloud" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="OpenAI" FontSize="11"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Cloud}"/>
                </Grid>
            </Border>

            <!-- Local card -->
            <Border Grid.Column="4" Tag="Local" MouseLeftButtonDown="CorrectionProviderCard_Click"
                    Cursor="Hand" BorderThickness="2"
                    Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CorrectionProvider}" Value="Local">
                                <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Local" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="LLM" FontSize="11"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource SelectedBorderBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Local}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Cloud correction settings -->
        <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Cloud}"
                    Margin="0,8,0,0">
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                <Grid Margin="20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Visibility="{Binding IsEditingCorrectionModel, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="Model" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CorrectionCloudModel}" FontSize="12"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBox Visibility="{Binding IsEditingCorrectionModel, Converter={StaticResource BoolToVisibility}}"
                             Text="{Binding CorrectionCloudModel}" Style="{StaticResource SettingsTextBoxStyle}"
                             KeyDown="CorrectionModelTextBox_KeyDown" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Change" Style="{StaticResource PillButtonStyle}"
                            Command="{Binding StartEditingCorrectionModelCommand}" VerticalAlignment="Center"
                            Visibility="{Binding IsEditingCorrectionModel, Converter={StaticResource InverseBoolToVisibility}}"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Local correction settings -->
        <StackPanel Visibility="{Binding CorrectionProvider, Converter={StaticResource StringToVisibility}, ConverterParameter=Local}"
                    Margin="0,8,0,0">
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                <Grid Margin="20,14,20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="GPU acceleration" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding CorrectionGpuAcceleration}"
                                  Command="{Binding ToggleCorrectionGpuAccelerationCommand}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Correction model list -->
            <ItemsControl ItemsSource="{Binding Models.CorrectionModelItems}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="16,12"
                                Background="{DynamicResource CardBgBrush}" CornerRadius="10"
                                BorderThickness="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBorderBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="12" Margin="8,0,0,0"
                                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                               FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <!-- Download -->
                                <Button Grid.Column="1" Content="Download" Cursor="Hand"
                                        FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center" Margin="10,0,0,0"
                                        Command="{Binding DataContext.Models.DownloadCorrectionModelCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource ModelActionVisibility}">
                                            <Binding Path="IsDownloaded"/>
                                            <Binding Path="IsDownloading"/>
                                        </MultiBinding>
                                    </Button.Visibility>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{DynamicResource CardBgBrush}"
                                                    CornerRadius="10" Padding="14,6"
                                                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Use -->
                                <Button Grid.Column="1" Content="Use" Cursor="Hand"
                                        FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center" Margin="10,0,0,0"
                                        Command="{Binding DataContext.Models.ActivateCorrectionModelCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource ModelUseVisibility}">
                                            <Binding Path="IsDownloaded"/>
                                            <Binding Path="IsDownloading"/>
                                            <Binding Path="IsActive"/>
                                        </MultiBinding>
                                    </Button.Visibility>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="#7C5CFC" CornerRadius="10" Padding="14,6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Foreground><SolidColorBrush Color="White"/></Button.Foreground>
                                </Button>
                                <!-- Delete -->
                                <Button Grid.Column="2" Content="Delete" Cursor="Hand"
                                        FontSize="12" FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center" Margin="6,0,0,0"
                                        Command="{Binding DataContext.Models.DeleteCorrectionModelCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource ModelDeleteVisibility}">
                                            <Binding Path="IsDownloaded"/>
                                            <Binding Path="IsDownloading"/>
                                            <Binding Path="IsActive"/>
                                        </MultiBinding>
                                    </Button.Visibility>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{DynamicResource CardBgBrush}"
                                                    CornerRadius="10" Padding="14,6"
                                                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Progress bar -->
                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Minimum="0" Maximum="1"
                                             Value="{Binding DownloadProgress}" Height="4" Margin="0,8,0,0"
                                             Foreground="#7C5CFC"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- ===== Combined Audio Model section (only for Cloud provider) ===== -->
        <StackPanel Visibility="{Binding Provider, Converter={StaticResource ProviderToVisibility}, ConverterParameter=OpenAI}">
        <TextBlock Text="Combined Audio Model" Style="{StaticResource GroupHeaderStyle}" Margin="0,20,0,8"/>
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
            <StackPanel>
                <Grid Margin="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#x2139;" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Top" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="11" FontFamily="Segoe UI Variable, Segoe UI"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Sends audio directly to OpenAI for transcription + correction in a single API call. Requires an API key."/>
                </Grid>
                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="20,0"/>
                <Grid Margin="20,14,20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Combined audio model" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CombinedAudioModel}" FontSize="12"
                                   FontFamily="Segoe UI Variable, Segoe UI" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"
                                   Visibility="{Binding UseCombinedAudioModel, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Change" Style="{StaticResource PillButtonStyle}"
                                Command="{Binding StartEditingCombinedAudioModelCommand}"
                                VerticalAlignment="Center" Margin="0,0,10,0"
                                Visibility="{Binding UseCombinedAudioModel, Converter={StaticResource BoolToVisibility}}"/>
                        <ToggleButton Style="{StaticResource ToggleSwitchStyle}"
                                      IsChecked="{Binding UseCombinedAudioModel}"
                                      Command="{Binding ToggleCombinedAudioModelCommand}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="20,0,20,14"
                      Visibility="{Binding IsEditingCombinedAudioModel, Converter={StaticResource BoolToVisibility}}">
                    <TextBox Text="{Binding CombinedAudioModel}" Style="{StaticResource SettingsTextBoxStyle}"
                             KeyDown="CombinedAudioModelTextBox_KeyDown"/>
                </Grid>
            </StackPanel>
        </Border>
        </StackPanel>

        <!-- Cloud usage hint -->
        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Margin="0,10,0,0"
                Visibility="{Binding ShowCloudUsageHint, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#x2139;" FontSize="16" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Top" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="Cloud text correction requires an OpenAI API key. Configure it above in the Transcription → Cloud section."/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
