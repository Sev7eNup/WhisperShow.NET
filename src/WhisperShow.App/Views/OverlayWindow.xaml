<Window x:Class="WhisperShow.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WhisperShow.App.ViewModels"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Width"
        Height="64"
        MinWidth="64"
        Left="100" Top="100">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="IdleBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="RecordingBrush" Color="#FFE53935"/>
        <SolidColorBrush x:Key="TranscribingBrush" Color="#FF1E88E5"/>
        <SolidColorBrush x:Key="ResultBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE53935"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#AAFFFFFF"/>

        <!-- Pulse animation for recording -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0.6" To="0.0" Duration="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1.0" To="1.5" Duration="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1.0" To="1.5" Duration="0:0:1"/>
        </Storyboard>

        <!-- Spinner rotation for transcribing -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Spinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1"/>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="32" Padding="0" x:Name="MainBorder"
            PreviewMouseLeftButtonDown="MainBorder_PreviewMouseLeftButtonDown"
            PreviewMouseMove="MainBorder_PreviewMouseMove"
            PreviewMouseLeftButtonUp="MainBorder_PreviewMouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <!-- Idle State -->
            <Grid x:Name="IdlePanel" Visibility="Visible">
                <Button Click="RecordButton_Click" Cursor="Hand"
                        Width="56" Height="56" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource IdleBrush}" CornerRadius="32"
                                    Width="56" Height="56">
                                <Path Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z"
                                      Fill="{StaticResource TextBrush}" Stretch="Uniform"
                                      Width="22" Height="22"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Recording State -->
            <Grid x:Name="RecordingPanel" Visibility="Collapsed">
                <!-- Pulse ring -->
                <Ellipse x:Name="PulseRing" Width="56" Height="56"
                         Stroke="{StaticResource RecordingBrush}" StrokeThickness="3"
                         Fill="Transparent" Opacity="0"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Button Click="RecordButton_Click" Cursor="Hand"
                        Width="56" Height="56" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource RecordingBrush}" CornerRadius="32"
                                    Width="56" Height="56">
                                <Rectangle Width="18" Height="18" Fill="{StaticResource TextBrush}"
                                           RadiusX="2" RadiusY="2"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Transcribing State -->
            <Grid x:Name="TranscribingPanel" Visibility="Collapsed">
                <Border Background="{StaticResource TranscribingBrush}" CornerRadius="32"
                        Width="56" Height="56">
                    <!-- Spinner -->
                    <Path x:Name="Spinner"
                          Data="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z"
                          Fill="{StaticResource TextBrush}" Stretch="Uniform"
                          Width="22" Height="22"
                          RenderTransformOrigin="0.5,0.5"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Path.RenderTransform>
                    </Path>
                </Border>
            </Grid>

            <!-- Result State -->
            <Grid x:Name="ResultPanel" Visibility="Collapsed">
                <Border Background="{StaticResource ResultBrush}" CornerRadius="28"
                        Padding="12,8" MinWidth="200" MaxWidth="500">
                    <StackPanel>
                        <TextBlock Text="{Binding TranscribedText}" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}" FontSize="13"
                                   MaxHeight="120" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Insert" Margin="0,0,6,0"
                                    Click="InsertButton_Click" Style="{x:Null}"
                                    Background="#FF4CAF50" Foreground="White"
                                    Padding="12,4" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Copy" Margin="0,0,6,0"
                                    Click="CopyButton_Click" Style="{x:Null}"
                                    Background="#FF555555" Foreground="White"
                                    Padding="12,4" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="X" Click="DismissButton_Click" Style="{x:Null}"
                                    Background="Transparent" Foreground="{StaticResource SubtleBrush}"
                                    Padding="6,4" Cursor="Hand"
                                    BorderThickness="0" FontWeight="Bold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Error State -->
            <Grid x:Name="ErrorPanel" Visibility="Collapsed">
                <Border Background="{StaticResource IdleBrush}" CornerRadius="28"
                        Padding="12,8" MinWidth="150" MaxWidth="400"
                        BorderBrush="{StaticResource ErrorBrush}" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                   Foreground="{StaticResource ErrorBrush}" FontSize="12"
                                   MaxHeight="60" Margin="0,0,0,6"/>
                        <Button Content="OK" Click="DismissButton_Click" Style="{x:Null}"
                                Background="#FF555555" Foreground="White"
                                Padding="12,4" Cursor="Hand" HorizontalAlignment="Right"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
