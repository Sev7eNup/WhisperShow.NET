<Window x:Class="WhisperShow.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WhisperShow.App.ViewModels"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinHeight="51"
        MinWidth="44"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Gradient Brushes -->
        <LinearGradientBrush x:Key="IdleGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF3A3A3A" Offset="0"/>
            <GradientStop Color="#FF2D2D2D" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="RecordingGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFEF5350" Offset="0"/>
            <GradientStop Color="#FFD32F2F" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="TranscribingGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF42A5F5" Offset="0"/>
            <GradientStop Color="#FF1565C0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Tail colors (match bottom gradient stop) -->
        <SolidColorBrush x:Key="IdleTailBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="RecordingTailBrush" Color="#FFD32F2F"/>
        <SolidColorBrush x:Key="TranscribingTailBrush" Color="#FF1565C0"/>

        <!-- Text colors -->
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#AAFFFFFF"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE53935"/>

        <!-- Breathing glow for recording -->
        <Storyboard x:Key="GlowPulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.4" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Typing dots for transcribing -->
        <Storyboard x:Key="TypingDotsAnimation" RepeatBehavior="Forever">
            <!-- Dot 1 -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1Transform"
                                           Storyboard.TargetProperty="Y"
                                           BeginTime="0:0:0">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.15" Value="-6">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint1="0.0,0.0" ControlPoint2="0.58,1.0"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint1="0.42,0.0" ControlPoint2="1.0,1.0"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Dot 2 -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2Transform"
                                           Storyboard.TargetProperty="Y"
                                           BeginTime="0:0:0.15">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.15" Value="-6">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint1="0.0,0.0" ControlPoint2="0.58,1.0"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint1="0.42,0.0" ControlPoint2="1.0,1.0"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Dot 3 -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3Transform"
                                           Storyboard.TargetProperty="Y"
                                           BeginTime="0:0:0.3">
                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:0.15" Value="-6">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint1="0.0,0.0" ControlPoint2="0.58,1.0"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
                    <SplineDoubleKeyFrame.KeySpline>
                        <KeySpline ControlPoint1="0.42,0.0" ControlPoint2="1.0,1.0"/>
                    </SplineDoubleKeyFrame.KeySpline>
                </SplineDoubleKeyFrame>
                <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <!-- Root grid for drag support -->
    <Grid x:Name="RootGrid"
          PreviewMouseLeftButtonDown="RootGrid_PreviewMouseLeftButtonDown"
          PreviewMouseMove="RootGrid_PreviewMouseMove"
          PreviewMouseLeftButtonUp="RootGrid_PreviewMouseLeftButtonUp">
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="OverlayScaleTransform" ScaleX="1" ScaleY="1"/>
        </Grid.LayoutTransform>

        <!-- Glow border behind bubble (for recording breathing effect) -->
        <Border x:Name="GlowBorder" Opacity="0" CornerRadius="14"
                Margin="-4,-4,-4,-2" IsHitTestVisible="False">
            <Border.Background>
                <SolidColorBrush Color="#FFEF5350"/>
            </Border.Background>
            <Border.Effect>
                <BlurEffect Radius="15"/>
            </Border.Effect>
        </Border>

        <!-- Speech bubble: body + tail -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Bubble body -->
            <Border x:Name="BubbleBody" Grid.Row="0" CornerRadius="12"
                    Background="{StaticResource IdleGradient}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Direction="270"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="BubbleScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>

                <Grid>
                    <!-- Idle State -->
                    <Grid x:Name="IdlePanel" Visibility="Visible">
                        <Button Click="RecordButton_Click" Cursor="Hand"
                                Width="44" Height="44" BorderThickness="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <ScaleTransform x:Name="IdleButtonScale" ScaleX="1" ScaleY="1"/>
                            </Button.RenderTransform>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Width="44" Height="44">
                                        <Path Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z"
                                              Fill="{StaticResource TextBrush}" Stretch="Uniform"
                                              Width="20" Height="20"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Recording State -->
                    <Grid x:Name="RecordingPanel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="3,0,0,0" Height="44">
                            <!-- Stop button -->
                            <Button Click="RecordButton_Click" Cursor="Hand"
                                    Width="34" Height="34" BorderThickness="0"
                                    VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" Width="34" Height="34">
                                            <Rectangle Width="11" Height="11" Fill="{StaticResource TextBrush}"
                                                       RadiusX="2" RadiusY="2"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Waveform visualization -->
                            <Canvas x:Name="WaveformCanvas" Width="72" Height="30"
                                    Margin="2,0,6,0" VerticalAlignment="Center"/>
                            <!-- Recording timer -->
                            <TextBlock Text="{Binding RecordingTimerText}"
                                       Foreground="{StaticResource TextBrush}" FontSize="11"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"
                                       Margin="2,0,8,0" Opacity="0.8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Transcribing State -->
                    <Grid x:Name="TranscribingPanel" Visibility="Collapsed"
                          Width="56" Height="44">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource TextBrush}"
                                     Margin="0,0,5,0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Dot1Transform"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="7" Height="7" Fill="{StaticResource TextBrush}"
                                     Margin="0,0,5,0" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Dot2Transform"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="7" Height="7" Fill="{StaticResource TextBrush}"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Dot3Transform"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </StackPanel>
                    </Grid>

                    <!-- Result State -->
                    <Grid x:Name="ResultPanel" Visibility="Collapsed"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="ResultTranslate"/>
                        </Grid.RenderTransform>
                        <StackPanel Margin="10,6" MinWidth="150" MaxWidth="500">
                            <TextBlock Text="{Binding TranscribedText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextBrush}" FontSize="11"
                                       MaxHeight="300" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Insert" Margin="0,0,4,0"
                                        Click="InsertButton_Click" Style="{x:Null}"
                                        Background="#FF4CAF50" Foreground="White"
                                        Padding="8,3" Cursor="Hand"
                                        BorderThickness="0" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="X" Click="DismissButton_Click" Style="{x:Null}"
                                        Background="Transparent" Foreground="{StaticResource SubtleBrush}"
                                        Padding="4,3" Cursor="Hand"
                                        BorderThickness="0" FontWeight="Bold" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Error State -->
                    <Grid x:Name="ErrorPanel" Visibility="Collapsed"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="ErrorTranslate"/>
                        </Grid.RenderTransform>
                        <Border Padding="10,6" MinWidth="120" MaxWidth="300"
                                BorderBrush="{StaticResource ErrorBrush}" BorderThickness="2"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                           Foreground="{StaticResource ErrorBrush}" FontSize="10"
                                           MaxHeight="120" Margin="0,0,0,4"/>
                                <Button Content="OK" Click="DismissButton_Click" Style="{x:Null}"
                                        Background="#FF555555" Foreground="White"
                                        Padding="8,3" Cursor="Hand" HorizontalAlignment="Right"
                                        BorderThickness="0" FontSize="11">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Bubble tail (triangle) -->
            <Path x:Name="BubbleTail" Grid.Row="1"
                  Data="M0,0 L6,7 L12,0 Z"
                  Fill="{StaticResource IdleTailBrush}"
                  HorizontalAlignment="Center"
                  Margin="0,-1,0,0"
                  IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</Window>
